<Application x:Class="ql_nhanSW.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ql_nhanSW"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="/Form/TrangChu/UC_NhanSu.xaml">

    <Application.Resources>
        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>

                <!-- Material Design Theme -->
                <materialDesign:BundledTheme BaseTheme="Light"
                                             PrimaryColor="DeepPurple"
                                             SecondaryColor="Lime"/>

                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml"/>

            </ResourceDictionary.MergedDictionaries>

            <!-- Title Font -->
            <Style x:Key="titleText" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="/Form/font/#Cyber Blast"/>
            </Style>

            <!-- SignIn Font -->
            <Style x:Key="SignInText" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="/Form/font/#VL Scriptonite"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>

</Application>