<Window x:Class="ql_nhanSW.Form.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"        
        xmlns:local="clr-namespace:ql_nhanSW.Form"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Login" Height="650" Width="875"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None">

    <Grid Margin="20">
        <Grid.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="1" Opacity="0.4" Color="#7C3AED"/>
        </Grid.Effect>

        <!-- ===== ĐĂNG NHẬP: Layout dọc, chiếm toàn màn hình ===== -->
        <Border x:Name="SignInPanel"
                Visibility="Visible"
                CornerRadius="16"
                MouseDown="Border_MouseDown" HorizontalAlignment="Right" Width="835">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0A0010" Offset="0"/>
                    <GradientStop Color="#0D0020" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <!-- Decorative circles -->
            <Grid>
                <Ellipse Width="400" Height="400"
                         HorizontalAlignment="Left" VerticalAlignment="Top"
                         Margin="-100,-100,0,0" Opacity="0.06">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#A855F7" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Ellipse Width="300" Height="300"
                         HorizontalAlignment="Right" VerticalAlignment="Bottom"
                         Margin="0,0,-80,-80" Opacity="0.08">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#7C3AED" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Content dọc -->
                <StackPanel Width="380"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <!-- LOGO + TÊN APP -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,28">
                        <Border Width="72" Height="72" CornerRadius="16"
                                Background="#7C3AED"
                                BorderBrush="#A855F7" BorderThickness="1.5"
                                HorizontalAlignment="Center" Margin="0,0,0,14">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#7C3AED" Opacity="0.7"/>
                            </Border.Effect>
                            <TextBlock Text="HR" Foreground="White" FontSize="26" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="HR PORTAL"
                                   Foreground="#E9D5FF" FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="MANAGEMENT V2"
                                   Foreground="#6B21A8" FontSize="10"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- FORM -->
                    <Border Background="#0D0020" BorderBrush="#3B0764" BorderThickness="1"
                            CornerRadius="12" Padding="28,24">
                        <StackPanel>

                            <TextBlock Text="ĐĂNG NHẬP"
                                       Foreground="#E9D5FF" FontSize="16" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="SYSTEM_ACCESS: AUTHORIZED"
                                       Foreground="#4C1D95" FontSize="9"
                                       HorizontalAlignment="Center" Margin="0,0,0,22"/>

                            <!-- Username -->
                            <TextBlock Text="TÊN ĐĂNG NHẬP" Foreground="#6B21A8"
                                       FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                            <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1"
                                    CornerRadius="8" Margin="0,0,0,14">
                                <TextBox x:Name="TxtUsername"
                                         Background="Transparent"
                                         Foreground="#E9D5FF" CaretBrush="#A855F7"
                                         BorderThickness="0" Padding="12,9"
                                         FontSize="13" FontFamily="Segoe UI"/>
                            </Border>

                            <!-- Password -->
                            <TextBlock Text="MẬT KHẨU" Foreground="#6B21A8"
                                       FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                            <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1"
                                    CornerRadius="8" Margin="0,0,0,8">
                                <PasswordBox x:Name="TxtPassword"
                                             Background="Transparent"
                                             Foreground="#E9D5FF" CaretBrush="#A855F7"
                                             BorderThickness="0" Padding="12,9"
                                             FontSize="13" FontFamily="Segoe UI"/>
                            </Border>

                            <TextBlock Text="Quên mật khẩu?" Foreground="#7C3AED"
                                       FontSize="11" HorizontalAlignment="Right"
                                       Cursor="Hand" Margin="0,0,0,20"/>

                            <!-- Nút đăng nhập -->
                            <Button Click="Login_Click"
                                    Background="#7C3AED" BorderThickness="0"
                                    Cursor="Hand" HorizontalAlignment="Stretch"
                                    Padding="0" Margin="0,0,0,10">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#6D28D9"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="ĐĂNG NHẬP" Foreground="White"
                                           FontSize="13" FontWeight="Bold" FontFamily="Segoe UI"/>
                            </Button>

                            <!-- Nút sang đăng ký -->
                            <Button Click="SwitchRegister_Click"
                                    Background="Transparent"
                                    BorderBrush="#3B0764" BorderThickness="1"
                                    Cursor="Hand" HorizontalAlignment="Stretch" Padding="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1A0035"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="Chưa có tài khoản? Đăng ký" Foreground="#9D78CC"
                                           FontSize="12" FontFamily="Segoe UI"/>
                            </Button>

                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== ĐĂNG KÝ: Layout ngang 2 cột ===== -->
        <Grid x:Name="SignUpPanel" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1.22*"/>
            </Grid.ColumnDefinitions>

            <!-- Cột trái: decoration -->
            <Border Grid.Column="0" CornerRadius="16,0,0,16" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0D0020" Offset="0"/>
                        <GradientStop Color="#1E0040" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Ellipse Width="350" Height="350"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Opacity="0.1">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#A855F7" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Width="200" Height="200"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="-40,0,0,-40" Opacity="0.12">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#7C3AED" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Width="60" Height="60" CornerRadius="12"
                                Background="#7C3AED" BorderBrush="#A855F7" BorderThickness="1.5"
                                HorizontalAlignment="Center" Margin="0,0,0,14">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" ShadowDepth="0" Color="#7C3AED" Opacity="0.6"/>
                            </Border.Effect>
                            <TextBlock Text="HR" Foreground="White" FontSize="20" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="HR PORTAL" Foreground="#E9D5FF"
                                   FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="MANAGEMENT V2" Foreground="#6B21A8"
                                   FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,28"/>

                        <Rectangle Height="1" Width="100" Fill="#2D0060" Margin="0,0,0,28"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Cột phải: form đăng ký -->
            <Border Grid.Column="1" Background="#0D0020"
                    CornerRadius="0,16,16,0"
                    BorderBrush="#2D0060" BorderThickness="1,0,0,0"
                    MouseDown="Border_MouseDown">
                <StackPanel VerticalAlignment="Center" Margin="36,0">

                    <TextBlock Text="ĐĂNG KÝ"
                               Foreground="#E9D5FF" FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="SYSTEM_REGISTER: NEW_USER"
                               Foreground="#4C1D95" FontSize="9"
                               HorizontalAlignment="Center" Margin="0,0,0,22"/>

                    <!-- Email -->
                    <TextBlock Text="EMAIL" Foreground="#6B21A8"
                               FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                    <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1"
                            CornerRadius="8" Margin="0,0,0,12">
                        <TextBox Background="Transparent" Foreground="#E9D5FF"
                                 CaretBrush="#A855F7" BorderThickness="0"
                                 Padding="12,9" FontSize="13" FontFamily="Segoe UI"/>
                    </Border>

                    <!-- Username -->
                    <TextBlock Text="TÊN ĐĂNG NHẬP" Foreground="#6B21A8"
                               FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                    <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1"
                            CornerRadius="8" Margin="0,0,0,12">
                        <TextBox Background="Transparent" Foreground="#E9D5FF"
                                 CaretBrush="#A855F7" BorderThickness="0"
                                 Padding="12,9" FontSize="13" FontFamily="Segoe UI"/>
                    </Border>

                    <!-- Password -->
                    <TextBlock Text="MẬT KHẨU" Foreground="#6B21A8"
                               FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                    <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1"
                            CornerRadius="8" Margin="0,0,0,12">
                        <PasswordBox Background="Transparent" Foreground="#E9D5FF"
                                     CaretBrush="#A855F7" BorderThickness="0"
                                     Padding="12,9" FontSize="13" FontFamily="Segoe UI"/>
                    </Border>

                    <!-- Confirm Password -->
                    <TextBlock Text="XÁC NHẬN MẬT KHẨU" Foreground="#6B21A8"
                               FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                    <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1"
                            CornerRadius="8" Margin="0,0,0,18">
                        <PasswordBox Background="Transparent" Foreground="#E9D5FF"
                                     CaretBrush="#A855F7" BorderThickness="0"
                                     Padding="12,9" FontSize="13" FontFamily="Segoe UI"/>
                    </Border>

                    <!-- Nút đăng ký -->
                    <Button Background="#7C3AED" BorderThickness="0"
                            Cursor="Hand" HorizontalAlignment="Stretch"
                            Padding="0" Margin="0,0,0,10">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#6D28D9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="ĐĂNG KÝ" Foreground="White"
                                   FontSize="13" FontWeight="Bold" FontFamily="Segoe UI"/>
                    </Button>

                    <!-- Quay lại đăng nhập -->
                    <Button Click="SwitchLogin_Click"
                            Background="Transparent"
                            BorderBrush="#3B0764" BorderThickness="1"
                            Cursor="Hand" HorizontalAlignment="Stretch" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1A0035"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="Đã có tài khoản? Đăng nhập" Foreground="#9D78CC"
                                   FontSize="12" FontFamily="Segoe UI"/>
                    </Button>

                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== LOADING OVERLAY ===== -->
        <Grid x:Name="LoadingOverlay"
              Visibility="Collapsed"
              Panel.ZIndex="99">
            <Rectangle Fill="#000000" Opacity="0.75" RadiusX="16" RadiusY="16"/>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True"
                             Width="70" Height="70"
                             Foreground="#A855F7"/>
                <TextBlock Text="Đang xác thực..."
                           Foreground="#E9D5FF" FontSize="18" FontWeight="Bold"
                           FontFamily="Segoe UI" Margin="0,20,0,8"
                           TextAlignment="Center"/>
                <TextBlock Text="Tài khoản của bạn đang được xét duyệt bởi quản trị viên.&#x0a;Vui lòng thử lại sau."
                           Foreground="#9D78CC" FontSize="12"
                           FontFamily="Segoe UI" TextAlignment="Center"
                           TextWrapping="Wrap" MaxWidth="300" Margin="0,0,0,24"/>
                <Button Content="ĐĂNG XUẤT"
                        Click="LogoutBtn_Click"
                        Width="180" Padding="0,10"
                        Background="Transparent"
                        BorderBrush="#7C3AED" BorderThickness="1"
                        FontFamily="Segoe UI" FontSize="13"
                        Foreground="White" Height="45">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>

    </Grid>
    
</Window>
