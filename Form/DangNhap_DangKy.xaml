<Window x:Class="ql_nhanSW.Form.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"        
        xmlns:local="clr-namespace:ql_nhanSW.Form"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Login" Height="650" Width="875"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        FontSize="18"
        FontFamily="{DynamicResource MaterialDesignFont}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None">
    <Grid Margin="20">
        <Grid.Effect>
            <DropShadowEffect BlurRadius="30"
                              ShadowDepth="1"
                              Opacity="0.4"/>
        </Grid.Effect>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1.22*"/>
        </Grid.ColumnDefinitions>

        <!--LEFT SECTION-->
        <Border x:Name="LeftBoard" CornerRadius="10 0 0 10" ClipToBounds="True">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#041348" Offset="0"/>
                    <GradientStop Color="#083e12" Offset="0.6"/>
                    <GradientStop Color="#1afe49" Offset="0.9"/>
                </LinearGradientBrush>
            </Border.Background>

            <Border.Clip>
                <RectangleGeometry Rect="0,0,400,605"
                                   RadiusX="10"
                                   RadiusY="10"/>
            </Border.Clip>

            <Grid>
                <!--TITLES-->
                <StackPanel Margin="0 150 0 0"
                            VerticalAlignment="Top">
                    <TextBlock Style="{StaticResource titleText}"
                               FontSize="60"
                               FontWeight="Bold"
                               Text="Fight Club"
                               Foreground="#1afe49"
                               TextAlignment="Center"/>
                    <TextBlock FontSize="16"
                               FontWeight="Light"
                               Text="Welcom to our App"
                               Foreground="#d1f2eb"
                               TextAlignment="Center"
                               Margin="0 15 0 3"/>
                </StackPanel>
                <!--Ellipses-->
                <Ellipse Width="500" Height="500"
                         VerticalAlignment="Bottom"
                         Fill="#1afe49"
                         Margin="50 0 0 -200"
                         Opacity="0.6"/>
                <Ellipse Width="300" Height="300"
                         VerticalAlignment="Bottom"
                         Fill="#1afe49"
                         Margin="-450 0 0 30"
                         Opacity="0.3"/>
                <Ellipse Width="400" Height="400"
                         VerticalAlignment="Bottom"
                         Fill="#1afe49"
                         Margin="-320 0 0 -120"
                         Opacity="0.3"/>
                <Ellipse Width="250" Height="250"
                         VerticalAlignment="Bottom"
                         Fill="#1afe49"
                         Margin="-380 0 0 -120"/>
                <Ellipse Width="400" Height="400"
                         VerticalAlignment="Bottom"
                         Fill="#1afe49"
                         Margin="280 0 0 -70"
                         Opacity="0.6"/>

                


            </Grid>
        </Border>
        <!--RGIHT SECTION-->
        <Border x:Name="RightBoard" Background="#ffffff"
                CornerRadius="0 10 10 0"
                MouseDown="Border_MouseDown" 
                Grid.ColumnSpan="2" Margin="376,0,0,5">
            <Grid>                
                <!--SIGN IN PANEL-->
                <StackPanel x:Name="SignInPanel"
                            Visibility="Visible"
                            VerticalAlignment="Center"
                            Margin="75 0">

                    <TextBlock Style="{StaticResource titleText}"
                               Text="Sign In"
                               FontSize="60"
                               HorizontalAlignment="Center"
                               Foreground="#083e12"/>

                    <TextBox Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Text=""
                             materialDesign:HintAssist.Hint="Username"
                             materialDesign:HintAssist.FloatingOffset="0,-20"
                             BorderBrush="#c5c8cc"
                             Margin="0 27"
                             FontFamily="Segoe UI"
                             BorderThickness="0 0 0 1.5"/>
                    <PasswordBox Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                                 Password=""
                                 materialDesign:HintAssist.Hint="Password"
                                 materialDesign:HintAssist.FloatingOffset="0,-20"
                                 BorderBrush="#c5c8cc"
                                 FontFamily="Segoe UI"
                                 Margin="0 0 0 27"
                                 BorderThickness="0 0 0 1.5"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Log In"
                                Foreground="#00ff9f"
                                Background="#083e12"
                                FontSize="16"
                                FontFamily="Segoe UI"
                                Width="120"
                                Height="45"
                                materialDesign:ButtonAssist.CornerRadius="22"
                                Click="Login_Click"
                                />
                        
                        <Button Content="or Sign Up"
                                Foreground="#083e12"
                                FontSize="16"
                                FontFamily="Segoe UI"
                                Width="120"
                                Height="45"
                                Margin="5 0 0 0"                                
                                Style="{StaticResource MaterialDesignFlatButton}"
                                materialDesign:ButtonAssist.CornerRadius="22"
                                Click="SwitchRegister_Click" RenderTransformOrigin="31.905,-2.563"/>
                    </StackPanel>                    
                </StackPanel>
                
                <!--SIGN UP PANEL-->
                <StackPanel x:Name="SignUpPanel"
                            Visibility="Collapsed"
                            VerticalAlignment="Center"
                            Margin="30 0">

                    <TextBlock Style="{StaticResource titleText}"
                               Text="Sign Up"
                               FontSize="60"
                               HorizontalAlignment="Center"
                               Foreground="#083e12"/>

                    <TextBox Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Text=""
                             materialDesign:HintAssist.Hint="Email"
                             materialDesign:HintAssist.FloatingOffset="0,-20"
                             BorderBrush="#c5c8cc"
                             Margin="0 27"
                             FontFamily="Segoe UI"
                             BorderThickness="0 0 0 1.5"/>
                    <TextBox Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Text=""
                             materialDesign:HintAssist.Hint="Username"
                             materialDesign:HintAssist.FloatingOffset="0,-20"
                             BorderBrush="#c5c8cc"
                             Margin="0 0 0 27"
                             FontFamily="Segoe UI"
                             BorderThickness="0 0 0 1.5"/>
                    <PasswordBox Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                                 Password=""
                                 materialDesign:HintAssist.Hint="Password"
                                 materialDesign:HintAssist.FloatingOffset="0,-20"
                                 BorderBrush="#c5c8cc"
                                 Margin="0 0 0 27"
                                 FontFamily="Segoe UI"                                 
                                 BorderThickness="0 0 0 1.5"/>
                    <PasswordBox Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                                 Password=""
                                 materialDesign:HintAssist.Hint="Confirm Password"
                                 materialDesign:HintAssist.FloatingOffset="0,-20"
                                 BorderBrush="#c5c8cc"
                                 FontFamily="Segoe UI"                                 
                                 BorderThickness="0 0 0 1.5"/>
                    <CheckBox Margin="0 20 0 20"
                              FontSize="13">
                        <TextBlock>
                            <Run Foreground="#b6b6b6" Text="By signing up I agree with "/>
                            <Run Foreground="#083e12 " Text="terms and conditions."/>
                        </TextBlock>
                    </CheckBox>
                    <StackPanel Orientation="Horizontal">
                        
                        <Button Content="Sign Up"
                                Foreground="#00ff9f"
                                Background="#083e12"
                                FontSize="16"
                                FontFamily="Segoe UI"
                                Width="120"
                                Height="45"
                                materialDesign:ButtonAssist.CornerRadius="22"/>
                        <Button Content="return to Login"
                                Foreground="#083e12"
                                FontSize="16"
                                FontFamily="Segoe UI"
                                Width="170"
                                Height="45"
                                Margin="5 0 0 0"                                
                                Style="{StaticResource MaterialDesignFlatButton}"
                                materialDesign:ButtonAssist.CornerRadius="22"
                                Click="SwitchLogin_Click" RenderTransformOrigin="31.905,-2.563"/>
                    </StackPanel>                    
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="LoadingOverlay"
              Visibility="Collapsed"
              Grid.ColumnSpan="2"
              Panel.ZIndex="99">

            <Rectangle Fill="#000000"
                       Opacity="0.65"
                       RadiusX="10" RadiusY="10"/>

            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True"
                             Width="70" Height="70"
                             Foreground="#1afe49"/>
                <TextBlock Text="Signing In..."
                           Foreground="White"
                           FontSize="16"
                           FontFamily="Segoe UI"
                           Margin="0 20 0 0"
                           TextAlignment="Center"/>
            </StackPanel>
        </Grid>

    </Grid>
    
</Window>
