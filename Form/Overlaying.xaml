<Window x:Class="ql_nhanSW.Form.Overlaying"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ql_nhanSW.Form"
        mc:Ignorable="d"
        Title="Overlaying" Height="450" Width="800">
    <!-- ===== LOADING OVERLAY ===== -->
    <Grid x:Name="LoadingOverlay"
      Visibility="Visible"
      Panel.ZIndex="99">
        <Rectangle Fill="#000000" Opacity="0.75" RadiusX="16" RadiusY="16"/>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                     IsIndeterminate="True"
                     Width="70" Height="70"
                     Foreground="#A855F7"/>
            <TextBlock Text="Đang xác thực..."
                   Foreground="#E9D5FF" FontSize="18" FontWeight="Bold"
                   FontFamily="Segoe UI" Margin="0,20,0,8"
                   TextAlignment="Center"/>
            <TextBlock Text="Tài khoản đang được xét duyệt bởi quản trị viên.&#x0a;Vui lòng thử lại sau."
                   Foreground="#9D78CC" FontSize="12"
                   FontFamily="Segoe UI" TextAlignment="Center"
                   TextWrapping="Wrap" MaxWidth="300" Margin="0,0,0,4"/>
        </StackPanel>
    </Grid>
</Window>
