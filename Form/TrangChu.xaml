<Window x:Class="ql_nhanSW.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ql_nhanSW"
        mc:Ignorable="d"
        Title="MainWindow" Height="700" Width="1080"
        WindowStartupLocation="CenterScreen"
        Background="#0A0010" FontFamily="Segoe UI">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!--LEFT TASK BAR-->
        <Border Grid.Column="0" Background="#0D0020"
                BorderBrush="#6B21A8"
                BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="False">
                <!--LOGO-->
                <Border DockPanel.Dock="Top"
                        Padding="16, 20, 16, 16"
                        BorderBrush="#3B0764"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="37" Height="37"
                                CornerRadius="10"
                                Background="#7C3AED"
                                BorderBrush="#A855F7" BorderThickness="1">
                            <TextBlock Text="HRM"
                                       Foreground="White"
                                       FontWeight="Bold" 
                                       FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" Width="30"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="HR Portal"
                                       Foreground="#E9D5FF"
                                       FontWeight="Bold" FontSize="13"/>
                            <TextBlock Text="MANAGEMENT V2"
                                       Foreground="#6B21A8"
                                       FontSize="9" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel DockPanel.Dock="Top" Margin="10,14,10,0">
                    <Button x:Name="BtnDashBoard" Click="BtnDashBoard_Click"
                            Background="#1E0040"
                            BorderThickness="1" BorderBrush="#7C3AED"
                            Padding="12,5"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Cursor="Hand"
                            FontFamily="Segoe UI"
                            FontSize="13">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Foreground="#C084FC" Text="⊞" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Foreground="#C084FC" Text="Bảng điều khiển" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnNhanSu" Background="Transparent" Foreground="#9D78CC"
                            BorderThickness="1" BorderBrush="#7C3AED"
                            Padding="12,5" HorizontalContentAlignment="Left" 
                            Cursor="Hand" Margin="0,0,0,2" Click="BtnNhanSu_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1A0035"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Quản lý nhân sự" Foreground="#9D78CC" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnPheDuyet" Background="Transparent" Foreground="#9D78CC"
                            BorderThickness="1" BorderBrush="#7C3AED" Padding="12,5"
                            HorizontalContentAlignment="Left" Cursor="Hand"
                            Margin="0,0,0,2" Click="BtnPheDuyet_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1A0035"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✓" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Phê duyệt tài khoản" Foreground="#9D78CC" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnCauHinhLuong" Background="Transparent" Foreground="#9D78CC"
                            BorderThickness="1" BorderBrush="#7C3AED" Padding="12,5"
                            HorizontalContentAlignment="Left" Cursor="Hand"
                            Margin="0,0,0,2" Click="BtnCauHinhLuong_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1A0035"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="$" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Cấu hình lương" Foreground="#9D78CC" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnBaoCaoTK" Background="Transparent" Foreground="#9D78CC"
                            BorderThickness="1" BorderBrush="#7C3AED" Padding="12,5"
                            HorizontalContentAlignment="Left" Cursor="Hand"
                            Click="BtnBaoCaoTK_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1A0035"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Báo cáo thống kê" Foreground="#9D78CC" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="10,0,10,16">
                    <Button Background="Transparent" Foreground="#9D78CC"
                            BorderThickness="0" Padding="12,5"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Cursor="Hand" FontFamily="Segoe UI" FontSize="13"
                            Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="14" Foreground="#9D78CC" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Cài đặt" FontSize="12" Foreground="#9D78CC" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1" CornerRadius="8" Padding="10">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="32" Height="32" CornerRadius="16"
                                    Background="#7C3AED"
                                    BorderBrush="#A855F7" BorderThickness="1.5">
                                <TextBlock Text="A" Foreground="White" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Admin" Foreground="#E9D5FF" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="Quản trị hệ thống" Foreground="#6B21A8" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <!--RIHGT BOARD-->
        <ContentControl x:Name="MainContent" Grid.Column="1"/>
    </Grid>
</Window>
