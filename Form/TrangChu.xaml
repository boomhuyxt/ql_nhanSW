<Window x:Class="ql_nhanSW.TrangChu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ql_nhanSW"
        mc:Ignorable="d"
        Title="MainWindow" Height="700" Width="1080"
        WindowStartupLocation="CenterScreen"
        Background="#0A0010" FontFamily="Segoe UI">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!--LEFT TASK BAR-->
        <Border Grid.Column="0" Background="#0D0020"
                BorderBrush="#6B21A8" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="False">
                <!--LOGO-->
                <Border DockPanel.Dock="Top" Padding="16,20,16,16"
                        BorderBrush="#3B0764" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="37" Height="37" CornerRadius="10"
                                Background="#7C3AED" BorderBrush="#A855F7" BorderThickness="1">
                            <TextBlock Text="HRM" Foreground="White" FontWeight="Bold"
                                       FontSize="13" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Width="30"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="HR Portal" Foreground="#E9D5FF" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Text="MANAGEMENT V2" Foreground="#6B21A8" FontSize="9" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel DockPanel.Dock="Top" Margin="10,14,10,0">
                    <Button x:Name="BtnDashBoard" Click="BtnDashBoard_Click"
                            Background="#1E0040" BorderThickness="1" BorderBrush="#7C3AED"
                            Padding="12,5" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left" Cursor="Hand" FontSize="13">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Foreground="#C084FC" Text="⊞" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Foreground="#C084FC" Text="Bảng điều khiển" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnNhanSu" Background="Transparent" Foreground="#9D78CC"
                            BorderThickness="1" BorderBrush="Transparent" Padding="12,5"
                            HorizontalContentAlignment="Left" Cursor="Hand"
                            Margin="0,2,0,0" Click="BtnNhanSu_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1A0035"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Quản lý nhân sự" Foreground="#9D78CC" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnPheDuyet" Background="Transparent" Foreground="#9D78CC"
                            BorderThickness="1" BorderBrush="Transparent" Padding="12,5"
                            HorizontalContentAlignment="Left" Cursor="Hand"
                            Margin="0,2,0,0" Click="BtnPheDuyet_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1A0035"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✓" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Phê duyệt tài khoản" Foreground="#9D78CC" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnCauHinhLuong" Background="Transparent" Foreground="#9D78CC"
                            BorderThickness="1" BorderBrush="Transparent" Padding="12,5"
                            HorizontalContentAlignment="Left" Cursor="Hand"
                            Margin="0,2,0,0" Click="BtnCauHinhLuong_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1A0035"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="$" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Cấu hình lương" Foreground="#9D78CC" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnBaoCaoTK" Background="Transparent" Foreground="#9D78CC"
                            BorderThickness="1" BorderBrush="Transparent" Padding="12,5"
                            HorizontalContentAlignment="Left" Cursor="Hand"
                            Click="BtnBaoCaoTK_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1A0035"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Báo cáo thống kê" Foreground="#9D78CC" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="10,0,10,16">
                    <Button Background="Transparent" Foreground="#9D78CC"
                            BorderThickness="0" Padding="12,5"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Cursor="Hand" FontSize="13" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="14" Foreground="#9D78CC" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Cài đặt" FontSize="12" Foreground="#9D78CC" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1" CornerRadius="8" Padding="10">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="32" Height="32" CornerRadius="16"
                                    Background="#7C3AED" BorderBrush="#A855F7" BorderThickness="1.5">
                                <TextBlock Text="A" Foreground="White" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Admin" Foreground="#E9D5FF" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="Quản trị hệ thống" Foreground="#6B21A8" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>
        <ContentControl x:Name="MainContent" Grid.Column="1"/>

        <!-- ===== CHATBOT ===== -->
        <Grid Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Right"
      Margin="0,0,24,24" Panel.ZIndex="99">

            <!-- Chat Panel -->
            <Border x:Name="ChatPanel"
            Visibility="Collapsed"
            Background="#0D0020"
            BorderBrush="#3B0764" BorderThickness="1"
            CornerRadius="16"
            Width="340" Height="480"
            VerticalAlignment="Bottom"
            Margin="0,0,0,62">
                <Border.Effect>
                    <DropShadowEffect Color="#7C3AED" BlurRadius="25" ShadowDepth="0" Opacity="0.4"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- HEADER -->
                    <Border Grid.Row="0" CornerRadius="16,16,0,0" Padding="16,14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#1E0040" Offset="0"/>
                                <GradientStop Color="#2D0060" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <!-- Avatar bot -->
                                <Border Width="36" Height="36" CornerRadius="18"
                                Background="#7C3AED" BorderBrush="#A855F7" BorderThickness="1.5"
                                Margin="0,0,10,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#7C3AED" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
                                    </Border.Effect>
                                    <Viewbox Width="20" Height="20">
                                        <Canvas Width="24" Height="24">
                                            <Rectangle Canvas.Left="4" Canvas.Top="3" Width="16" Height="11"
                                               RadiusX="3" RadiusY="3" Fill="White"/>
                                            <Ellipse Canvas.Left="7" Canvas.Top="6" Width="3" Height="3" Fill="#7C3AED"/>
                                            <Ellipse Canvas.Left="14" Canvas.Top="6" Width="3" Height="3" Fill="#7C3AED"/>
                                            <Rectangle Canvas.Left="8" Canvas.Top="10" Width="8" Height="2"
                                               RadiusX="1" RadiusY="1" Fill="#7C3AED"/>
                                            <Rectangle Canvas.Left="5" Canvas.Top="15" Width="14" Height="7"
                                               RadiusX="2" RadiusY="2" Fill="White"/>
                                            <Rectangle Canvas.Left="11" Canvas.Top="1" Width="2" Height="3" Fill="White"/>
                                            <Ellipse Canvas.Left="9.5" Canvas.Top="0" Width="5" Height="5" Fill="#A855F7"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>

                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="HR Assistant" Foreground="#E9D5FF"
                                       FontSize="13" FontWeight="Bold"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="6" Height="6" Fill="#4ADE80"
                                         VerticalAlignment="Center" Margin="0,0,5,0">
                                            <Ellipse.Effect>
                                                <DropShadowEffect Color="#4ADE80" BlurRadius="5" ShadowDepth="0"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                        <TextBlock Text="Đang hoạt động" Foreground="#4ADE80" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- Nút đóng -->
                            <Button x:Name="BtnCloseChat" Click="BtnCloseChat_Click"
                            Background="Transparent" BorderThickness="0"
                            HorizontalAlignment="Right" Cursor="Hand" Width="28" Height="28">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6" Padding="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#3B0764"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="✕" Foreground="#9D78CC" FontSize="12"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Đường kẻ phân cách -->
                    <Rectangle Grid.Row="0" Height="1" Fill="#2D0060"
                       VerticalAlignment="Bottom"/>

                    <!-- MESSAGES -->
                    <ScrollViewer Grid.Row="1" x:Name="ChatScrollViewer"
                          VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ChatMessages" Margin="14,14,14,8">

                            <!-- Tin nhắn mặc định bot -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="28" Height="28" CornerRadius="14"
                                Background="#7C3AED" VerticalAlignment="Bottom" Margin="0,0,8,0">
                                    <TextBlock Text="AI" Foreground="White" FontSize="9" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Background="#1E0040" BorderBrush="#3B0764" BorderThickness="1"
                                CornerRadius="12,12,12,2" Padding="12,10" MaxWidth="220">
                                    <StackPanel>
                                        <TextBlock Text="Xin chào! 👋" Foreground="#E9D5FF"
                                           FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                                        <TextBlock Text="Tôi là HR Assistant. Tôi có thể giúp bạn tra cứu thông tin nhân sự, lương thưởng và nhiều hơn nữa!"
                                           Foreground="#D8B4FE" FontSize="12"
                                           TextWrapping="Wrap" FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Quick replies -->
                            <StackPanel Margin="36,0,0,12">
                                <TextBlock Text="Gợi ý nhanh:" Foreground="#6B21A8"
                                   FontSize="10" Margin="0,0,0,6"/>
                                <WrapPanel>
                                    <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1"
                                    CornerRadius="12" Padding="10,5" Margin="0,0,6,6" Cursor="Hand">
                                        <TextBlock Text="📊 Xem báo cáo" Foreground="#C084FC" FontSize="11"/>
                                    </Border>
                                    <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1"
                                    CornerRadius="12" Padding="10,5" Margin="0,0,6,6" Cursor="Hand">
                                        <TextBlock Text="👥 Nhân sự" Foreground="#C084FC" FontSize="11"/>
                                    </Border>
                                    <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1"
                                    CornerRadius="12" Padding="10,5" Margin="0,0,6,6" Cursor="Hand">
                                        <TextBlock Text="💰 Lương tháng" Foreground="#C084FC" FontSize="11"/>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- INPUT -->
                    <Border Grid.Row="2" BorderBrush="#2D0060" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,16,16" Background="#080015" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#150028"
                            BorderBrush="#3B0764" BorderThickness="1"
                            CornerRadius="20" Margin="0,0,8,0">
                                <TextBox x:Name="ChatInput"
                                 Background="Transparent"
                                 Foreground="#E9D5FF" CaretBrush="#A855F7"
                                 BorderThickness="0" Padding="14,9"
                                 FontSize="12" FontFamily="Segoe UI"
                                 KeyDown="ChatInput_KeyDown"
                                 VerticalContentAlignment="Center"/>
                            </Border>

                            <Button Grid.Column="1" Click="BtnSendChat_Click"
                            Background="#7C3AED" BorderThickness="0"
                            Cursor="Hand" Width="38" Height="38">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="19">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#7C3AED" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                                            </Border.Effect>
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#6D28D9"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="➤" Foreground="White" FontSize="14" Margin="2,0,0,0"/>
                            </Button>
                        </Grid>
                    </Border>

                </Grid>
            </Border>

            <!-- TOGGLE BUTTON -->
            <Button x:Name="BtnToggleChat" Click="BtnToggleChat_Click"
            Background="#7C3AED" BorderThickness="0"
            Width="52" Height="52"
            HorizontalAlignment="Center" VerticalAlignment="Top"
            Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="26">
                            <Border.Effect>
                                <DropShadowEffect Color="#7C3AED" BlurRadius="18" ShadowDepth="0" Opacity="0.7"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6D28D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <!-- Icon robot -->
                <Viewbox Width="26" Height="26">
                    <Canvas Width="24" Height="24">
                        <Rectangle Canvas.Left="4" Canvas.Top="3" Width="16" Height="11"
                           RadiusX="3" RadiusY="3" Fill="White"/>
                        <Ellipse Canvas.Left="7" Canvas.Top="6" Width="3" Height="3" Fill="#7C3AED"/>
                        <Ellipse Canvas.Left="14" Canvas.Top="6" Width="3" Height="3" Fill="#7C3AED"/>
                        <Rectangle Canvas.Left="8" Canvas.Top="10" Width="8" Height="2"
                           RadiusX="1" RadiusY="1" Fill="#7C3AED"/>
                        <Rectangle Canvas.Left="5" Canvas.Top="15" Width="14" Height="7"
                           RadiusX="2" RadiusY="2" Fill="White"/>
                        <Rectangle Canvas.Left="11" Canvas.Top="1" Width="2" Height="3" Fill="White"/>
                        <Ellipse Canvas.Left="9.5" Canvas.Top="0" Width="5" Height="5" Fill="#A855F7"/>
                    </Canvas>
                </Viewbox>
            </Button>

        </Grid>
    </Grid>
</Window>
