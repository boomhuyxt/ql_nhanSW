<UserControl x:Class="ql_nhanSW.Form.TrangChu.BanDieuKhien"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:ql_nhanSW.Form"
             mc:Ignorable="d"
             Background="#F8FAFC" FontFamily="Segoe UI">
    <DockPanel LastChildFill="False" Width="811">
        <Border DockPanel.Dock="Top" Background="#FFFFFF" Padding="24,16" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <TextBlock Text="BẢNG ĐIỀU KHIỂN CÁ NHÂN" Foreground="#1E1B4B" FontSize="18" FontWeight="Bold"/>
        </Border>

        <StackPanel DockPanel.Dock="Top" Margin="24, 20, 24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E9D5FF" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,10,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Opacity="0.05" Color="#7C3AED"/>
                    </Border.Effect>
                    <StackPanel>
                        <Border Width="36" Height="36" CornerRadius="8" Background="#F5F3FF" HorizontalAlignment="Left" Margin="0,0,0,10">
                            <TextBlock Foreground="#7C3AED" Text="🏢" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Phòng ban đang công tác" Foreground="#64748B" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock x:Name="txtPhongBan" Text="Đang tải..." Foreground="#4C1D95" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#E9D5FF" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,10,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Opacity="0.05" Color="#7C3AED"/>
                    </Border.Effect>
                    <StackPanel>
                        <Border Width="36" Height="36" CornerRadius="8" Background="#F0FDF4" HorizontalAlignment="Left" Margin="0,0,0,10">
                            <TextBlock Foreground="#16A34A" Text="💰" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Lương tháng gần nhất" Foreground="#64748B" FontSize="11" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="txtLuong" Text="0" Foreground="#16A34A" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text=" đ" Foreground="#16A34A" FontSize="12" VerticalAlignment="Bottom" Margin="2,0,0,5"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#E9D5FF" BorderThickness="1" CornerRadius="12" Padding="16">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Opacity="0.05" Color="#7C3AED"/>
                    </Border.Effect>
                    <StackPanel>
                        <Border Width="36" Height="36" CornerRadius="8" Background="#FFFBEB" HorizontalAlignment="Left" Margin="0,0,0,10">
                            <TextBlock Foreground="#D97706" Text="🕒" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Trạng thái chấm công" Foreground="#64748B" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock x:Name="txtTrangThaiChamCong" Text="CHƯA XÁC ĐỊNH" Foreground="#D97706" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>

        <Grid DockPanel.Dock="Top" Margin="24,16,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,13,0">
                <Border Background="#FFFFFF" BorderBrush="#E9D5FF" BorderThickness="1" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <TextBlock Text="📝" Foreground="#7C3AED" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="ĐĂNG KÝ NGHỈ PHÉP" Foreground="#4C1D95" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Ngày bắt đầu" Foreground="#64748B" FontSize="11" Margin="0,0,0,5" FontWeight="SemiBold"/>
                                <DatePicker x:Name="dpStart" Height="34"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Ngày kết thúc" Foreground="#64748B" FontSize="11" Margin="0,0,0,5" FontWeight="SemiBold"/>
                                <DatePicker x:Name="dpEnd" Height="34"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Loại nghỉ" Foreground="#64748B" FontSize="11" Margin="0,15,0,5" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cbLoaiNghi" Height="34" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="Nghỉ phép"/>
                            <ComboBoxItem Content="Nghỉ thai sản"/>
                            <ComboBoxItem Content="Nghỉ bệnh"/>
                            <ComboBoxItem Content="Khác"/>
                        </ComboBox>

                        <TextBlock Text="Minh chứng (Ảnh/Word/PDF)" Foreground="#64748B" FontSize="11" Margin="0,15,0,5" FontWeight="SemiBold"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtFilePath" IsReadOnly="True" Height="34" Background="#FDFBFF" BorderBrush="#DDD6FE" Padding="10,0" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="1" Content="📁 Tải file" Click="BtnUpload_Click" Margin="8,1,0,1" Background="#F5F3FF" Foreground="#7C3AED" BorderBrush="#E9D5FF" BorderThickness="1" Cursor="Hand" FontWeight="SemiBold" HorizontalAlignment="Left" Width="97"/>
                        </Grid>

                        <Button Content="GỬI ĐƠN PHÊ DUYỆT" Click="BtnGuiDon_Click" Margin="0,24,0,0" Height="42" Background="#7C3AED" Foreground="White" FontWeight="Bold" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <TextBlock Text="📊" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Biến động lương 6 tháng" Foreground="#1E1B4B" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>

                        <ItemsControl x:Name="ChartLuong" Height="150" VerticalAlignment="Bottom">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="6,0" VerticalAlignment="Bottom">
                                        <TextBlock Text="{Binding ValueDisplay}" Foreground="#7C3AED" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <Border Width="22" Height="{Binding ColumnHeight}" Background="#7C3AED" CornerRadius="4,4,0,0">
                                            <Border.ToolTip>
                                                <ToolTip Content="{Binding FullInfo}"/>
                                            </Border.ToolTip>
                                        </Border>
                                        <TextBlock Text="{Binding Label}" Foreground="#64748B" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="15">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="📅" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Trạng thái đơn nghỉ" Foreground="#1E1B4B" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
                            <ItemsControl x:Name="ItemsTrangThaiNghiPhep">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding LoaiNghi}" FontWeight="SemiBold" Foreground="#4C1D95" FontSize="12"/>
                                                    <TextBlock Text="{Binding NgayBatDau, StringFormat='Ngày: dd/MM/yyyy'}" FontSize="10" Foreground="#64748B"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#F1F5F9"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding TrangThai}" Value="Chờ duyệt">
                                                                    <Setter Property="Background" Value="#FFFBEB"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding TrangThai}" Value="Đã chấp nhận">
                                                                    <Setter Property="Background" Value="#F0FDF4"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding TrangThai}" Value="Từ chối">
                                                                    <Setter Property="Background" Value="#FEF2F2"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding TrangThai}" FontSize="9" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#64748B"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding TrangThai}" Value="Chờ duyệt">
                                                                        <Setter Property="Foreground" Value="#D97706"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding TrangThai}" Value="Đã chấp nhận">
                                                                        <Setter Property="Foreground" Value="#16A34A"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding TrangThai}" Value="Từ chối">
                                                                        <Setter Property="Foreground" Value="#DC2626"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </DockPanel>
</UserControl>