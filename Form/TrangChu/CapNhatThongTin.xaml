<UserControl x:Class="ql_nhanSW.Form.TrangChu.CapNhatThongTin"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:ql_nhanSW.Form.TrangChu"
             mc:Ignorable="d"
             Background="Transparent" FontFamily="Segoe UI"
             d:DesignHeight="780" d:DesignWidth="750">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,40">

        <StackPanel HorizontalAlignment="Center" MaxWidth="680" Margin="20,40,20,20">

            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,32">
                <TextBlock Text="Thông tin Tài khoản" Foreground="#E9D5FF" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <Border Width="120" Height="120" CornerRadius="60" Background="#150028" BorderBrush="#7C3AED" BorderThickness="2" Margin="0,0,0,16">
                    <Grid>
                        <TextBlock Text="👤" Foreground="#6B21A8" FontSize="50" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Image x:Name="imgAvatar" Stretch="UniformToFill">
                            <Image.Clip>
                                <EllipseGeometry RadiusX="60" RadiusY="60" Center="60,60"/>
                            </Image.Clip>
                        </Image>
                    </Grid>
                </Border>

                <Button x:Name="btnChonAnh" Click="btnChonAnh_Click" Content="📷 Thay đổi ảnh đại diện" 
                        Background="Transparent" Foreground="#C084FC" BorderBrush="#4C1D95" BorderThickness="1" 
                        FontSize="13" FontWeight="SemiBold" Padding="16,8" Cursor="Hand" HorizontalAlignment="Center" Height="37">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1A0035"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <Border Background="#0D0020" BorderBrush="#3B0764" BorderThickness="1" CornerRadius="12" Padding="32,24,32,32" Width="679" Height="405">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <TextBlock Text="🔒" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Chi tiết liên hệ &amp; Đăng nhập" Foreground="#E9D5FF" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Tên đăng nhập" Foreground="#6B21A8" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1" CornerRadius="6" Margin="0,0,0,20">
                                <TextBox x:Name="txtTenDangNhap" Background="Transparent" Foreground="#E9D5FF" BorderThickness="0" Padding="14,12" FontSize="14"/>
                            </Border>

                            <TextBlock Text="Số điện thoại" Foreground="#6B21A8" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1" CornerRadius="6" Margin="0,0,0,20">
                                <TextBox x:Name="txtSoDienThoai" Background="Transparent" Foreground="#E9D5FF" BorderThickness="0" Padding="14,12" FontSize="14"/>
                            </Border>

                            <TextBlock Text="Giới tính" Foreground="#6B21A8" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1" CornerRadius="6" Padding="14,12" Height="46">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <RadioButton x:Name="rdoNam" Content="Nam" Foreground="#E9D5FF" FontSize="14" Margin="0,0,40,0" IsChecked="True" VerticalContentAlignment="Center"/>
                                    <RadioButton x:Name="rdoNu" Content="Nữ" Foreground="#E9D5FF" FontSize="14" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Email liên hệ" Foreground="#6B21A8" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1" CornerRadius="6" Margin="0,0,0,20">
                                <TextBox x:Name="txtEmail" Background="Transparent" Foreground="#E9D5FF" BorderThickness="0" Padding="14,12" FontSize="14"/>
                            </Border>

                            <TextBlock Text="Ngày sinh" Foreground="#6B21A8" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1" CornerRadius="6" Margin="0,0,0,20" Padding="10,8">
                                <DatePicker x:Name="dpNgaySinh" Background="Transparent" BorderThickness="0" FontSize="14" VerticalContentAlignment="Center"/>
                            </Border>

                            <TextBlock Text="Địa chỉ" Foreground="#6B21A8" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1" CornerRadius="6" Height="46">
                                <TextBox x:Name="txtDiaChi" Background="Transparent" Foreground="#E9D5FF" BorderThickness="0" Padding="14,12" FontSize="14" TextWrapping="Wrap" AcceptsReturn="True"/>
                            </Border>
                        </StackPanel>

                    </Grid>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">

                <Button x:Name="btnHuy" Click="btnHuy_Click" Content="Hủy bỏ" Background="Transparent" Foreground="#D8B4FE" 
                        BorderBrush="#4C1D95" BorderThickness="1" FontSize="14" FontWeight="SemiBold" Padding="24,10" Cursor="Hand" Height="44">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1A0035"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="btnLuu" Click="btnLuu_Click" Content="💾 Cập nhật" Background="#7C3AED" Foreground="White" 
                        BorderThickness="0" FontSize="14" FontWeight="SemiBold" Padding="32,10" Cursor="Hand" Height="44" RenderTransformOrigin="0.515,-1.407">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#6D28D9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>