<UserControl x:Class="ql_nhanSW.Form.TrangChu.UC_BCTK"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:local="clr-namespace:ql_nhanSW.Form"
        mc:Ignorable="d"
        
        Background="#0A0010" FontFamily="Segoe UI">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Background="#0D0020"
                Padding="24,16"
                BorderBrush="#2D0060"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center" Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="TỔNG QUAN"
                                Foreground="#E9D5FF"
                                FontSize="18" FontWeight="Bold"
                                />

                        <Border Width="350" Background="#150028"
                                BorderBrush="#4C1D95" BorderThickness="1"
                                CornerRadius="8" Padding="10,6" Margin="20,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE721;" 
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="12" 
                                            Foreground="#4C1D95"
                                            Margin="0,0,6,0" 
                                            VerticalAlignment="Center"/>
                                <TextBlock VerticalAlignment="Center" Text="Tìm kiếm nhân sự..."
                                            Foreground="#4C1D95" FontSize="12"
                                            FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">

                    <Border Width="32" Height="32" CornerRadius="8"
                        Background="#150028" BorderBrush="#4C1D95" BorderThickness="1"
                        Margin="8,0,0,0" Cursor="Hand">
                        <TextBlock Foreground="#9D78CC" Text="🔔" FontSize="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                    </Border>
                    <Border Width="32" Height="32" CornerRadius="8"
                        Background="#150028" BorderBrush="#4C1D95" BorderThickness="1"
                        Margin="8,0,0,0" Cursor="Hand">
                        <Border Width="20" Height="20" CornerRadius="10"
                            Background="Transparent"
                            BorderBrush="#0D0020" BorderThickness="1">
                            <TextBlock Text="?" 
                                    FontSize="13" 
                                    FontWeight="Bold"
                                    Foreground="#9D78CC"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Border>
                    <Button Click="BtnOpenChat_Click"
                            Background="Transparent" BorderThickness="1" BorderBrush="#4C1D95"
                            Cursor="Hand" Width="32" Height="32" Margin="8,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1E0040"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Viewbox Width="18" Height="18">
                            <Canvas Width="24" Height="24">

                                <Rectangle Canvas.Left="4" Canvas.Top="3" Width="16" Height="11"
                                           RadiusX="3" RadiusY="3"
                                           Fill="Transparent" Stroke="#6B21A8" StrokeThickness="1.5"/>

                                <Ellipse Canvas.Left="7.5" Canvas.Top="6.5" Width="2.5" Height="2.5"
                                         Fill="#9D78CC"/>

                                <Ellipse Canvas.Left="14" Canvas.Top="6.5" Width="2.5" Height="2.5"
                                         Fill="#9D78CC"/>

                                <Rectangle Canvas.Left="8.5" Canvas.Top="10.5" Width="7" Height="1.5"
                                           RadiusX="1" RadiusY="1" Fill="#9D78CC"/>

                                <Rectangle Canvas.Left="5" Canvas.Top="15" Width="14" Height="7"
                                           RadiusX="2" RadiusY="2"
                                           Fill="Transparent" Stroke="#6B21A8" StrokeThickness="1.5"/>

                                <Line X1="12" Y1="3" X2="12" Y2="1" Stroke="Transparent" StrokeThickness="1.5"/>

                                <Ellipse Canvas.Left="10" Canvas.Top="0" Width="4" Height="4"
                                         Fill="Transparent" Stroke="#6B21A8" StrokeThickness="1.5"/>

                                <Rectangle Canvas.Left="2" Canvas.Top="16" Width="3" Height="5"
                                           RadiusX="1" RadiusY="1"
                                           Fill="Transparent" Stroke="#6B21A8" StrokeThickness="1.5"/>

                                <Rectangle Canvas.Left="19" Canvas.Top="16" Width="3" Height="5"
                                           RadiusX="1" RadiusY="1"
                                           Fill="Transparent" Stroke="#6B21A8" StrokeThickness="1.5"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--KPI CARDS-->
        <StackPanel DockPanel.Dock="Top" Margin="24, 20, 24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!--TỔNG NHÂN SỰ-->
                <Border Grid.Column="0"
                        Background="#0D0020"
                        BorderBrush="#3B0764" BorderThickness="1"
                        CornerRadius="12" 
                        Padding="16" Margin="0,0,10,0">

                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="#1A1200" BorderBrush="#713F12" BorderThickness="1"
                                    HorizontalAlignment="Right" Margin="107,0,0,0">
                                <Viewbox Width="16" Height="16">
                                    <Path Fill="#FFD700" Stretch="Uniform">
                                        <Path.Data>
                                            <GeometryGroup>
                                                <EllipseGeometry Center="20 18" RadiusX="10" RadiusY="10"/>
                                                <RectangleGeometry Rect="6 27 28 15" RadiusX="14" RadiusY="14"/>

                                                <EllipseGeometry Center="42 22" RadiusX="7" RadiusY="7"/>
                                                <RectangleGeometry Rect="33 30 18 11" RadiusX="11" RadiusY="11"/>
                                            </GeometryGroup>
                                        </Path.Data>
                                    </Path>
                                </Viewbox>
                            </Border>
                            <TextBlock Text="Tổng nhân sự" Foreground="#E9D5FF" 
                                       FontSize="12"
                                       HorizontalAlignment="Left" VerticalAlignment="Center"
                                       Margin="0,0,0,4"/>
                        </Grid>

                        <TextBlock Text="1,284" Foreground="#E9D5FF" FontSize="24" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M16,6l2.29,2.29l-4.88,4.88l-4-4L2,16.59L3.41,18l6-6l4,4l6.3-6.29L22,12V6H16z" 
                                  Fill="#00C853" Stretch="Uniform"
                                  HorizontalAlignment="Left"
                                  Width="16" Height="16" />
                            <TextBlock Text="+12%" Foreground="#00C853" FontSize="11"
                                       Margin="2,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock Text="so với tháng trước" Foreground="#E9D5FF" FontSize="11"
                                       Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <!--Tỷ lệ chuyên cần-->
                <Border Grid.Column="1"
                        Background="#0D0020"
                        BorderBrush="#3B0764" BorderThickness="1"
                        CornerRadius="12" 
                        Padding="16" Margin="0,0,10,0">

                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="#0A2000" BorderBrush="#14532D" BorderThickness="1"
                                    HorizontalAlignment="Right" Margin="107,0,0,0">
                                <TextBlock Text="📊" 
                                           Foreground="#00C853" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="16"/>

                            </Border>
                            <TextBlock Text="Tỷ lệ chuyên cần" Foreground="#E9D5FF" 
                                       FontSize="12"
                                       HorizontalAlignment="Left" VerticalAlignment="Center"
                                       Margin="0,0,0,4"/>
                        </Grid>

                        <TextBlock Text="96.5%" Foreground="#E9D5FF" FontSize="24" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M16,6l2.29,2.29l-4.88,4.88l-4-4L2,16.59L3.41,18l6-6l4,4l6.3-6.29L22,12V6H16z" 
                                  Fill="#00C853" Stretch="Uniform"
                                  HorizontalAlignment="Left"
                                  Width="16" Height="16" />
                            <TextBlock Text="+1.1%" Foreground="#00C853" FontSize="11"
                                       Margin="2,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock Text="so với hôm qua" Foreground="#E9D5FF" FontSize="11"
                                       Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2"
                        Background="#0D0020"
                        BorderBrush="#3B0764" BorderThickness="1"
                        CornerRadius="12" 
                        Padding="16" Margin="0,0,10,0">

                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="#1A1200" BorderBrush="#713F12" BorderThickness="1"
                                    HorizontalAlignment="Right" Margin="107,0,0,0">
                                <Path Data="M14,2H6C4.9,2,4,2.9,4,4V20C4,21.1,4.9,22,6,22H18C19.1,22,20,21.1,20,20V8L14,2M16,16L12,20L10,18L11.41,16.59L12,17.17L14.59,14.58L16,16M13,9V3.5L18.5,9H13Z" 
                                      Fill="#FACC15" 
                                      Stretch="Uniform" 
                                      Width="16" Height="16"/>

                            </Border>
                            <TextBlock Text="Công việc cần làm" Foreground="#E9D5FF" 
                                       FontSize="12"
                                       HorizontalAlignment="Left" VerticalAlignment="Center"
                                       Margin="0,0,0,4"/>
                        </Grid>

                        <TextBlock Text="24" Foreground="#E9D5FF" FontSize="24" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M16,18l2.29-2.29l-4.88-4.88l-4,4L2,7.41L3.41,6l6,6l4-4l6.3,6.29L22,12v6H16z" 
                                  Fill="#D32F2F" 
                                  Stretch="Uniform"
                                  HorizontalAlignment="Left"
                                  Width="16" Height="16" />
                            <TextBlock Text="-2.0%" Foreground="#EF5350" FontSize="11"
                                       Margin="2,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock Text="so với tuần trước" Foreground="#E9D5FF" FontSize="11"
                                       Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3"
                        Background="#0D0020"
                        BorderBrush="#3B0764" BorderThickness="1"
                        CornerRadius="12" 
                        Padding="16" Margin="0,0,10,0">

                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="#1E0040" BorderBrush="#4C1D95" BorderThickness="1"
                                    HorizontalAlignment="Right" Margin="107,0,0,0">
                                <Path Width="16" Height="16" 
                                      Fill="#4C1D95" Stretch="Uniform" 
                                      Data="M 24 8 C 28.42 8 32 11.58 32 16 C 32 20.42 28.42 24 24 24 C 19.58 24 16 20.42 16 16 C 16 11.58 19.58 8 24 8 Z M 24 28 C 32.84 28 40 33.16 40 39.5 V 44 H 8 V 39.5 C 8 33.16 15.16 28 24 28 Z M 48 16 V 24 H 40 V 28 H 48 V 36 H 52 V 28 H 60 V 24 H 52 V 16 H 48 Z" />

                            </Border>
                            <TextBlock Text="Vị trí tuyển dụng" Foreground="#E9D5FF" 
                                       FontSize="12"
                                       HorizontalAlignment="Left" VerticalAlignment="Center"
                                       Margin="0,0,0,4"/>
                        </Grid>

                        <TextBlock Text="18" Foreground="#E9D5FF" FontSize="24" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M16,6l2.29,2.29l-4.88,4.88l-4-4L2,16.59L3.41,18l6-6l4,4l6.3-6.29L22,12V6H16z" 
                                  Fill="#00C853" Stretch="Uniform"
                                  HorizontalAlignment="Left"
                                  Width="16" Height="16" />
                            <TextBlock Text="+3" Foreground="#00C853" FontSize="11"
                                       Margin="2,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock Text="mới trong tuần này" Foreground="#E9D5FF" FontSize="11"
                                       Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </Grid>
        </StackPanel>

        <!-- BOTTOM ROW -->
        <Grid DockPanel.Dock="Top" Margin="24,26,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Biểu đồ đường chuyên cần -->
            <Border Grid.Column="0"
                    Background="#0D0020"
                    BorderBrush="#3B0764" BorderThickness="1"
                    CornerRadius="12" Padding="16">
                <StackPanel>
                    <TextBlock Text="Biểu đồ chuyên cần" FontSize="16"
                               Foreground="#E9D5FF" FontWeight="Bold"/>
                    <TextBlock Text="30 ngày qua" FontSize="12"
                               Foreground="#3B0764" Margin="0,0,0,12"/>

                    <!-- Container cho biểu đồ đường -->
                    <Grid  x:Name="LineChartContainer" Height="220" Background="Transparent"/>
                </StackPanel>
            </Border>

            <!-- Biểu đồ cột số lượng nhân sự -->
            <Border Grid.Column="2"
                    Background="#0D0020"
                    BorderBrush="#3B0764" BorderThickness="1"
                    CornerRadius="12" Padding="16">
                <StackPanel>
                    <TextBlock Text="Số lượng nhân sự" FontSize="16"
                               Foreground="#E9D5FF" FontWeight="Bold"/>
                    <TextBlock Text="Theo phòng ban" FontSize="12"
                               Foreground="#3B0764" Margin="0,0,0,12"/>

                    <!-- Container cho biểu đồ cột -->
                    <Grid x:Name="BarChartContainer" Height="220" Background="Transparent"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
