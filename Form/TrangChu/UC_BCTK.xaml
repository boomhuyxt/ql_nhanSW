<UserControl x:Class="ql_nhanSW.Form.TrangChu.UC_BCTK"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="#F8FAFC" FontFamily="Segoe UI">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="#FFFFFF" Padding="20,15" BorderBrush="#E9D5FF" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="BÁO CÁO CHI TIẾT &amp; THỐNG KÊ" Foreground="#4C1D95" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Tìm kiếm nhân viên:" VerticalAlignment="Center" Foreground="#64748B" Margin="0,0,10,0"/>
                    <Grid Width="280">
                        <TextBox x:Name="txtSearchNhanVien" Height="32" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#DDD6FE" TextChanged="txtSearchNhanVien_TextChanged"/>

                        <TextBlock IsHitTestVisible="False" Text="Nhập tên nhân viên..." VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="#94A3B8" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtSearchNhanVien}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Popup x:Name="popGoiY" PlacementTarget="{Binding ElementName=txtSearchNhanVien}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                            <Border Background="White" BorderBrush="#DDD6FE" BorderThickness="1" CornerRadius="0,0,8,8" Width="280" MaxHeight="250">
                                <ListBox x:Name="lstGoiY" BorderThickness="0" SelectionChanged="lstGoiY_SelectionChanged" Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="5">
                                                <TextBlock Text="{Binding HoTen}" FontWeight="Bold" Foreground="#1E1B4B"/>
                                                <TextBlock Text="{Binding Email}" FontSize="10" Foreground="#6B21A8" Opacity="0.7"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Popup>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <UniformGrid DockPanel.Dock="Top" Columns="3" Margin="20,15,20,0">
            <Border Background="#FFFFFF" BorderBrush="#E9D5FF" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="👥" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="Tổng nhân sự" FontSize="11" Foreground="#64748B"/>
                        <TextBlock x:Name="txtTongNhanSu" Text="0" Foreground="#7C3AED" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="#FFFFFF" BorderBrush="#E9D5FF" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📝" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="Công việc" FontSize="11" Foreground="#64748B"/>
                        <TextBlock x:Name="txtCongViec" Text="24" Foreground="#7C3AED" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="#FFFFFF" BorderBrush="#E9D5FF" BorderThickness="1" CornerRadius="12" Padding="12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="👤" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="Tuyển dụng" FontSize="11" Foreground="#64748B"/>
                        <TextBlock x:Name="txtTuyenDung" Text="0" Foreground="#7C3AED" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="15">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Tỷ lệ chuyên cần (%)" Foreground="#1E1B4B" FontWeight="Bold" Margin="0,0,0,15"/>

                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <ComboBox x:Name="cbExportChuyenCan" Width="80" Height="28" FontSize="11" SelectedIndex="0" Margin="0,0,5,0">
                            <ComboBoxItem Content="Excel"/>
                            <ComboBoxItem Content="PDF"/>
                        </ComboBox>
                        <Button Content="Xuất file" Name="BtnExportChuyenCan" Background="#16A34A" Foreground="White" Padding="10,0" Height="28" Click="BtnExport_Click"/>
                    </StackPanel>

                    <Canvas x:Name="CanvasChuyenCan" Background="#FDFBFF" Height="220">
                        <Polyline x:Name="PolyChuyenCan" Stroke="#7C3AED" StrokeThickness="2"/>
                    </Canvas>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="15">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Biến động chi trả lương (Triệu VNĐ)" Foreground="#1E1B4B" FontWeight="Bold" Margin="0,0,0,15"/>

                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <ComboBox x:Name="cbExportLuong" Width="80" Height="28" FontSize="11" SelectedIndex="0" Margin="0,0,5,0">
                            <ComboBoxItem Content="Excel"/>
                            <ComboBoxItem Content="PDF"/>
                        </ComboBox>
                        <Button Content="Xuất file" Name="BtnExportLuong" Background="#16A34A" Foreground="White" Padding="10,0" Height="28" Click="BtnExport_Click"/>
                    </StackPanel>

                    <Canvas x:Name="CanvasLuong" Background="#FDFBFF" Height="220">
                        <Polyline x:Name="PolyLuong" Stroke="#16A34A" StrokeThickness="2"/>
                    </Canvas>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>