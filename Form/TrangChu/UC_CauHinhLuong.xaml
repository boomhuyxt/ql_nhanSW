<UserControl x:Class="ql_nhanSW.Form.TrangChu.UC_CauHinhLuong"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0A0010"
             FontFamily="Segoe UI">
    <DockPanel LastChildFill="False">
                        
            <Border DockPanel.Dock="Top"
                Background="#0D0020"
                Padding="24,16"
                BorderBrush="#2D0060"
                BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Tính toán Lương tháng 10/2023"
                       Foreground="#E9D5FF"
                       FontSize="18" FontWeight="Bold"
                       FontFamily="Segoe UI"/>                            
                        </StackPanel>

                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Border Background="#150028"
                BorderBrush="#4C1D95" BorderThickness="1"
                CornerRadius="8" Padding="10,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE721;" 
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="12" 
                           Foreground="#4C1D95"
                           Margin="0,0,6,0" 
                           VerticalAlignment="Center"/>
                                <TextBlock VerticalAlignment="Center" Text="Tìm kiếm nhân sự..."
                           Foreground="#4C1D95" FontSize="12"
                           FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>
                        <Border Width="32" Height="32" CornerRadius="8"
                Background="#150028" BorderBrush="#4C1D95" BorderThickness="1"
                Margin="8,0,0,0" Cursor="Hand">
                            <TextBlock Foreground="#4C1D95" Text="🔔" FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                        </Border>
                        <Border Width="32" Height="32" CornerRadius="8"
                Background="#150028" BorderBrush="#4C1D95" BorderThickness="1"
                Margin="6,0,0,0" Cursor="Hand">
                            <Border Width="20" Height="20" CornerRadius="10"
                    Background="Transparent"
                    BorderBrush="#6B21A8" BorderThickness="1">
                                <TextBlock Text="?" 
                           FontSize="13" 
                           FontWeight="Bold"
                           Foreground="#9D78CC"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Border>
                        <Button Click="BtnOpenChat_Click"
Background="Transparent" BorderThickness="1" BorderBrush="#4C1D95"
Cursor="Hand" Width="36" Height="36" Margin="6,0,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1E0040"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Viewbox Width="18" Height="18">
                                <Canvas Width="24" Height="24">

                                    <Rectangle Canvas.Left="4" Canvas.Top="3" Width="16" Height="11"
           RadiusX="3" RadiusY="3"
           Fill="Transparent" Stroke="#6B21A8" StrokeThickness="1.5"/>

                                    <Ellipse Canvas.Left="7.5" Canvas.Top="6.5" Width="2.5" Height="2.5"
         Fill="#9D78CC"/>

                                    <Ellipse Canvas.Left="14" Canvas.Top="6.5" Width="2.5" Height="2.5"
         Fill="#9D78CC"/>

                                    <Rectangle Canvas.Left="8.5" Canvas.Top="10.5" Width="7" Height="1.5"
           RadiusX="1" RadiusY="1" Fill="#9D78CC"/>

                                    <Rectangle Canvas.Left="5" Canvas.Top="15" Width="14" Height="7"
           RadiusX="2" RadiusY="2"
           Fill="Transparent" Stroke="#6B21A8" StrokeThickness="1.5"/>

                                    <Line X1="12" Y1="3" X2="12" Y2="1" Stroke="Transparent" StrokeThickness="1.5"/>

                                    <Ellipse Canvas.Left="10" Canvas.Top="0" Width="4" Height="4"
         Fill="Transparent" Stroke="#6B21A8" StrokeThickness="1.5"/>

                                    <Rectangle Canvas.Left="2" Canvas.Top="16" Width="3" Height="5"
           RadiusX="1" RadiusY="1"
           Fill="Transparent" Stroke="#6B21A8" StrokeThickness="1.5"/>

                                    <Rectangle Canvas.Left="19" Canvas.Top="16" Width="3" Height="5"
           RadiusX="1" RadiusY="1"
           Fill="Transparent" Stroke="#6B21A8" StrokeThickness="1.5"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,24">

                <!-- MAIN ROW -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="240"/>
                    </Grid.ColumnDefinitions>

                    <!-- CỘT TRÁI -->
                    <StackPanel Grid.Column="0">

                        <!-- CHỌN NHÂN VIÊN -->
                        <Border Background="#0D0020" BorderBrush="#3B0764" BorderThickness="1"
                                CornerRadius="12" Padding="16" Margin="0,0,0,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                    <TextBlock Text="👤" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Chọn Nhân viên"
                                               Foreground="#E9D5FF" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Search + Phòng ban -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="160"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Search box -->
                                    <Border Grid.Column="0" Background="#150028"
                                            BorderBrush="#4C1D95" BorderThickness="1" CornerRadius="8">
                                        <StackPanel Orientation="Horizontal" Margin="10,8">
                                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="12" Foreground="#6B21A8" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Nhập tên hoặc mã nhân viên (VD: NV001)..."
                                                       Foreground="#4C1D95" FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Phòng ban dropdown -->
                                    <Border Grid.Column="2" Background="#150028"
                                            BorderBrush="#4C1D95" BorderThickness="1" CornerRadius="8">
                                        <Grid Margin="10,8">
                                            <TextBlock Text="Tất cả phòng ban" Foreground="#9D78CC" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBlock Text="▾" Foreground="#6B21A8" FontSize="12"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- Nhân viên được chọn -->
                                <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1" CornerRadius="10" Padding="12">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="42" Height="42" CornerRadius="21"
                                                    Background="#2D0060" BorderBrush="#7C3AED" BorderThickness="1.5">
                                                <TextBlock Text="NA" Foreground="White" FontSize="13" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="Nguyễn Văn An" Foreground="#E9D5FF" FontSize="13" FontWeight="Bold"/>
                                                <TextBlock Text="MNV: NV001  •  Software Engineer  •  Senior"
                                                           Foreground="#6B21A8" FontSize="10" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Background="#052E16" BorderBrush="#14532D" BorderThickness="1"
                                                CornerRadius="4" Padding="8,4">
                                            <TextBlock Text="ĐANG HOẠT ĐỘNG" Foreground="#4ADE80" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- CHI TIẾT CÁC KHOẢN -->
                        <Border Background="#0D0020" BorderBrush="#3B0764" BorderThickness="1"
                                CornerRadius="12" Padding="16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock Text="⚡" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Chi tiết các khoản"
                                               Foreground="#E9D5FF" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- 3 khoản -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Lương cơ bản -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="LƯƠNG CƠ BẢN (VNĐ)" Foreground="#6B21A8" FontSize="9" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                            <TextBlock Text="25,000,000" Foreground="#E9D5FF" FontSize="14" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Thưởng -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="THƯỞNG (BONUS)" Foreground="#6B21A8" FontSize="9" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <Border Background="#0A2000" BorderBrush="#14532D" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                            <TextBlock Text="2,500,000" Foreground="#4ADE80" FontSize="14" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Khấu trừ -->
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="KHẤU TRỪ (DEDUCTIONS)" Foreground="#6B21A8" FontSize="9" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <Border Background="#1F0000" BorderBrush="#7F1D1D" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                            <TextBlock Text="1,200,000" Foreground="#F87171" FontSize="14" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <Rectangle Height="1" Fill="#2D0060" Margin="0,0,0,16"/>

                                <!-- Tổng lương -->
                                <Grid Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Tổng lương thực nhận"
                                                   Foreground="#E9D5FF" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                                        <TextBlock Text="Sau khi đã tính toán các khoản thưởng và khấu trừ thuế tự động."
                                                   Foreground="#6B21A8" FontSize="11"/>
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="26,300,000" Foreground="#A855F7" FontSize="24" FontWeight="Bold" HorizontalAlignment="Right"/>
                                        <TextBlock Text="VND" Foreground="#7C3AED" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Nút xác nhận -->
                                <Button Background="#7C3AED" BorderThickness="0"
                                        Cursor="Hand" HorizontalAlignment="Stretch" Padding="0"
                                        Margin="0,0,0,8">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#6D28D9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚙ " Foreground="White" FontSize="13"/>
                                        <TextBlock Text="Xác nhận &amp; Xuất lương" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock Text="Lưu ý: Sau khi xác nhận, nhân viên sẽ nhận được thông báo qua Email và Portal cá nhân ngay lập tức."
                                           Foreground="#4C1D95" FontSize="10" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>

                    <!-- CỘT PHẢI -->
                    <StackPanel Grid.Column="2">

                        <!-- THỐNG KÊ -->
                        <Border Background="#4C1D95" BorderBrush="#7C3AED" BorderThickness="1"
                                CornerRadius="12" Padding="16" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="THỐNG KÊ CHI TRẢ THÁNG 10"
                                           Foreground="#E9D5FF" FontSize="10" FontWeight="Bold" Margin="0,0,0,14"/>

                                <TextBlock Text="Tổng quỹ lương:" Foreground="#C4B5FD" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock Text="4.2 Tỷ" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>

                                <TextBlock Text="Đã giải ngân:" Foreground="#C4B5FD" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock Text="1.8 Tỷ (42%)" Foreground="#4ADE80" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                                <Border Height="6" CornerRadius="3" Background="#3B0764">
                                    <Border HorizontalAlignment="Left" Width="100" CornerRadius="3" Height="6" Background="#4ADE80"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- GHI CHÚ NHANH -->
                        <Border Background="#0D0020" BorderBrush="#3B0764" BorderThickness="1"
                                CornerRadius="12" Padding="16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="📝" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Ghi chú nhanh"
                                               Foreground="#E9D5FF" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Note 1 -->
                                <Border Background="#1A0035" BorderBrush="#7C3AED" BorderThickness="0,0,0,3"
                                        CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                    <TextBlock Text="Có 5 nhân viên mới cần cập nhật lương cơ bản."
                                               Foreground="#D8B4FE" FontSize="11" TextWrapping="Wrap"/>
                                </Border>

                                <!-- Note 2 -->
                                <Border Background="#1A0035" BorderBrush="#FACC15" BorderThickness="0,0,0,3"
                                        CornerRadius="6" Padding="10" Margin="0,0,0,14">
                                    <TextBlock Text="Khấu trừ bảo hiểm thay đổi theo quy định mới từ 01/10."
                                               Foreground="#D8B4FE" FontSize="11" TextWrapping="Wrap"/>
                                </Border>

                                <TextBlock Text="THÊM GHI CHÚ" Foreground="#6B21A8" FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                                <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1" CornerRadius="8" Padding="10">
                                    <TextBlock Text="Nhập ghi chú cho bảng lương tháng này..."
                                               Foreground="#4C1D95" FontSize="11" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>

                <!-- LỊCH SỬ XUẤT LƯƠNG -->
                <Border Background="#0D0020" BorderBrush="#3B0764" BorderThickness="1"
                        CornerRadius="12" Padding="16" Margin="0,14,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🕐" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Lịch sử xuất lương tháng này"
                                           Foreground="#E9D5FF" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" Background="Transparent"
                                    BorderBrush="#3B0764" BorderThickness="1"
                                    Cursor="Hand" Padding="12,6">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⬇ " Foreground="#9D78CC" FontSize="11"/>
                                    <TextBlock Text="Xuất báo cáo (Excel)" Foreground="#9D78CC" FontSize="11"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Table header -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="NHÂN VIÊN"    Foreground="#6B21A8" FontSize="9" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Text="LƯƠNG CƠ BẢN" Foreground="#6B21A8" FontSize="9" FontWeight="Bold"/>
                            <TextBlock Grid.Column="2" Text="THỰC NHẬN"    Foreground="#6B21A8" FontSize="9" FontWeight="Bold"/>
                            <TextBlock Grid.Column="3" Text="NGÀY XUẤT"    Foreground="#6B21A8" FontSize="9" FontWeight="Bold"/>
                            <TextBlock Grid.Column="4" Text="TRẠNG THÁI"   Foreground="#6B21A8" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="#2D0060" Margin="0,0,0,10"/>

                        <!-- Row 1 -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Border Width="28" Height="28" CornerRadius="14"
                                        Background="#1E0040" BorderBrush="#7C3AED" BorderThickness="1">
                                    <TextBlock Text="NA" Foreground="White" FontSize="8" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Nguyễn Văn An" Foreground="#D8B4FE" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="NV001" Foreground="#6B21A8" FontSize="10"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="25,000,000" Foreground="#9D78CC" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="26,300,000" Foreground="#4ADE80" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="01/10/2023" Foreground="#6B21A8" FontSize="11" VerticalAlignment="Center"/>
                            <Border Grid.Column="4" Background="#052E16" BorderBrush="#14532D" BorderThickness="1"
                                    CornerRadius="4" Padding="6,3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="ĐÃ XUẤT" Foreground="#4ADE80" FontSize="9" FontWeight="Bold"/>
                            </Border>
                        </Grid>

                        <!-- Row 2 -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Border Width="28" Height="28" CornerRadius="14"
                                        Background="#0A2000" BorderBrush="#7C3AED" BorderThickness="1">
                                    <TextBlock Text="TH" Foreground="White" FontSize="8" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Trần Thị Hoa" Foreground="#D8B4FE" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="NV002" Foreground="#6B21A8" FontSize="10"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="20,000,000" Foreground="#9D78CC" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="21,500,000" Foreground="#4ADE80" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="01/10/2023" Foreground="#6B21A8" FontSize="11" VerticalAlignment="Center"/>
                            <Border Grid.Column="4" Background="#052E16" BorderBrush="#14532D" BorderThickness="1"
                                    CornerRadius="4" Padding="6,3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="ĐÃ XUẤT" Foreground="#4ADE80" FontSize="9" FontWeight="Bold"/>
                            </Border>
                        </Grid>

                        <!-- Row 3 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Border Width="28" Height="28" CornerRadius="14"
                                        Background="#2D0060" BorderBrush="#7C3AED" BorderThickness="1">
                                    <TextBlock Text="LM" Foreground="White" FontSize="8" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Lê Minh Tuấn" Foreground="#D8B4FE" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="NV003" Foreground="#6B21A8" FontSize="10"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="18,000,000" Foreground="#9D78CC" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="18,000,000" Foreground="#FACC15" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="--/--/----"  Foreground="#6B21A8" FontSize="11" VerticalAlignment="Center"/>
                            <Border Grid.Column="4" Background="#1A1200" BorderBrush="#713F12" BorderThickness="1"
                                    CornerRadius="4" Padding="6,3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="CHỜ DUYỆT" Foreground="#FACC15" FontSize="9" FontWeight="Bold"/>
                            </Border>
                        </Grid>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>