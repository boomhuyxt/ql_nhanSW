<UserControl x:Class="ql_nhanSW.Form.TrangChu.UC_CauHinhLuong"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24">
            <TextBlock Text="Tính toán Lương nhân sự" 
                       Foreground="#1E1B4B" FontSize="20" FontWeight="Bold" Margin="0,0,0,6"/>
            <TextBlock Text="Quản lý, điều chỉnh và phê duyệt chi trả lương cho nhân sự toàn hệ thống. Mọi thay đổi sẽ được ghi nhật ký hệ thống." 
                       Foreground="#64748B" FontSize="12" Margin="0,0,0,20" TextWrapping="Wrap"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Background="#FFFFFF" BorderBrush="#E9D5FF" BorderThickness="1" 
                            CornerRadius="12" Padding="16" Margin="0,0,0,14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <TextBlock Text="👤" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Chọn Nhân viên cần tính lương" 
                                           Foreground="#4C1D95" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Border Background="#FDFBFF" BorderBrush="#DDD6FE" BorderThickness="1" 
                                    CornerRadius="8" Margin="0,0,0,14">
                                <ComboBox x:Name="cmbNhanVien" 
                                          Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                          Padding="8" FontSize="13" Foreground="#1E1B4B"
                                          SelectionChanged="cmbNhanVien_SelectionChanged">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding HoTen}" FontWeight="Bold" Width="120" Foreground="#1E1B4B"/>
                                                <TextBlock Text=" | " Foreground="#DDD6FE"/>
                                                <TextBlock Text="{Binding GioiTinh}" Width="50" Foreground="#64748B"/>
                                                <TextBlock Text=" | " Foreground="#DDD6FE"/>
                                                <TextBlock Text="{Binding NgaySinh, StringFormat={}{0:dd/MM/yyyy}}" Foreground="#64748B"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Border>

                            <Border Background="#F5F3FF" BorderBrush="#E9D5FF" BorderThickness="1" CornerRadius="10" Padding="12">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="42" Height="42" CornerRadius="21" 
                                            Background="#7C3AED" BorderBrush="#A855F7" BorderThickness="1.5">
                                        <TextBlock Text="HR" Foreground="White" FontSize="13" FontWeight="Bold" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="txtHoTen" Text="Chưa chọn nhân viên" Foreground="#1E1B4B" FontSize="13" FontWeight="Bold"/>
                                        <TextBlock x:Name="txtMaNV" Text="MNV: -- | Giới tính: --" 
                                                   Foreground="#7C3AED" FontSize="10" Margin="0,3,0,0" FontWeight="Medium"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFFFFF" BorderBrush="#E9D5FF" BorderThickness="1" 
                            CornerRadius="12" Padding="16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="⚡" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Nhập thông tin tính lương" 
                                           Foreground="#4C1D95" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Tháng" Grid.Row="0" Grid.Column="0" Foreground="#64748B" FontSize="12" VerticalAlignment="Center"/>
                                <Border Grid.Row="0" Grid.Column="1" Background="#FDFBFF" BorderBrush="#DDD6FE" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10">
                                    <TextBox x:Name="txtThang" Background="Transparent" Foreground="#1E1B4B" BorderThickness="0" Padding="8,8"/>
                                </Border>

                                <TextBlock Text="Năm" Grid.Row="0" Grid.Column="3" Foreground="#64748B" FontSize="12" VerticalAlignment="Center"/>
                                <Border Grid.Row="0" Grid.Column="4" Background="#FDFBFF" BorderBrush="#DDD6FE" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10">
                                    <TextBox x:Name="txtNam" Background="Transparent" Foreground="#1E1B4B" BorderThickness="0" Padding="8,8"/>
                                </Border>

                                <TextBlock Text="Lương cơ bản" Grid.Row="1" Grid.Column="0" Foreground="#64748B" FontSize="12" VerticalAlignment="Center"/>
                                <Border Grid.Row="1" Grid.Column="1" Background="#FDFBFF" BorderBrush="#7C3AED" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10">
                                    <TextBox x:Name="txtLuongCoBan" Text="0" Background="Transparent" Foreground="#1E1B4B" FontWeight="Bold" BorderThickness="0" Padding="8,8"/>
                                </Border>

                                <TextBlock Text="Thưởng/KPI" Grid.Row="1" Grid.Column="3" Foreground="#64748B" FontSize="12" VerticalAlignment="Center"/>
                                <Border Grid.Row="1" Grid.Column="4" Background="#FDFBFF" BorderBrush="#DDD6FE" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10">
                                    <TextBox x:Name="txtThuong" Text="0" Background="Transparent" Foreground="#1E1B4B" BorderThickness="0" Padding="8,8"/>
                                </Border>

                                <TextBlock Text="Số ngày công" Grid.Row="2" Grid.Column="0" Foreground="#64748B" FontSize="12" VerticalAlignment="Center"/>
                                <Border Grid.Row="2" Grid.Column="1" Background="#FDFBFF" BorderBrush="#DDD6FE" BorderThickness="1" CornerRadius="6">
                                    <TextBox x:Name="txtSoNgayCong" Text="26" Background="Transparent" Foreground="#1E1B4B" BorderThickness="0" Padding="8,8"/>
                                </Border>

                                <TextBlock Text="Khấu trừ (TĐ)" Grid.Row="2" Grid.Column="3" Foreground="#64748B" FontSize="11" VerticalAlignment="Center"/>
                                <Border Grid.Row="2" Grid.Column="4" Background="#FFF1F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="6">
                                    <TextBox x:Name="txtKhauTru" Text="0" IsReadOnly="True" Background="Transparent" Foreground="#E11D48" BorderThickness="0" Padding="8,8" FontWeight="Bold"/>
                                </Border>
                            </Grid>

                            <Button x:Name="btnTinhLuong" Content="🔢 Tính Lương (Áp dụng Thuế &amp; BH)" 
                                    Background="#7C3AED" Foreground="White" FontWeight="SemiBold"
                                    Padding="20,10" Click="btnTinhLuong_Click" Height="43" Cursor="Hand"/>

                            <StackPanel Orientation="Horizontal" Margin="0,20,0,16">
                                <TextBlock Text="📊" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Kết quả tính toán thực nhận" Foreground="#4C1D95" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="LƯƠNG CƠ BẢN" Foreground="#6B21A8" FontSize="9" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Border Background="#FDFBFF" BorderBrush="#E9D5FF" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                        <TextBlock x:Name="tbLuongCoBan" Text="0" Foreground="#1E1B4B" FontSize="14" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="THƯỞNG/KPI" Foreground="#6B21A8" FontSize="9" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Border Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                        <TextBlock x:Name="tbThuong" Text="0" Foreground="#16A34A" FontSize="14" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="KHẤU TRỪ (TỔNG)" Foreground="#6B21A8" FontSize="9" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Border Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                        <TextBlock x:Name="tbKhauTru" Text="0" Foreground="#DC2626" FontSize="14" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Rectangle Height="1" Fill="#F1F5F9" Margin="0,0,0,16"/>

                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Tổng lương thực nhận" 
                                               Foreground="#1E1B4B" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="Đã khấu trừ 10.5% BH và 10% Thuế TNCN." 
                                               Foreground="#64748B" FontSize="11"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock x:Name="tbTongLuong" Text="0" Foreground="#7C3AED" FontSize="24" FontWeight="Bold"/>
                                    <TextBlock Text=" VND" Foreground="#7C3AED" FontSize="14" FontWeight="Bold" VerticalAlignment="Bottom" Margin="5,0,0,5"/>
                                </StackPanel>
                            </Grid>

                            <Button x:Name="btnXacNhanXuatLuong" Background="#7C3AED" BorderThickness="0" Cursor="Hand" 
                                    HorizontalAlignment="Stretch" Padding="0" Margin="0,20,0,8" 
                                    Click="btnXacNhanXuatLuong_Click" Height="45">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#6D28D9"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙ " Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Xác nhận &amp; Lưu vào hệ thống" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Background="#7C3AED" BorderBrush="#A855F7" BorderThickness="1" 
                            CornerRadius="12" Padding="20" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="THỐNG KÊ CHI TRẢ" 
                                       Foreground="White" FontSize="10" FontWeight="Bold" Margin="0,0,0,14" Opacity="0.9"/>

                            <TextBlock Text="Quỹ lương tháng hiện tại:" Foreground="#DDD6FE" FontSize="13" Margin="0,0,0,6"/>

                            <TextBlock x:Name="txtTongQuyLuong" Text="0 VND" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>

                            <TextBlock Text="Tiến độ ngân sách dự kiến:" Foreground="#DDD6FE" FontSize="11" Margin="0,0,0,8"/>
                            <Border Height="8" CornerRadius="4" Background="#5B21B6">
                                <Border x:Name="rectProgress" HorizontalAlignment="Left" Width="0" CornerRadius="4" Height="8" Background="#4ADE80"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFFFFF" BorderBrush="#E9D5FF" BorderThickness="1" 
                            CornerRadius="12" Padding="16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="📝" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Ghi chú nhanh" Foreground="#4C1D95" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Background="#F5F3FF" BorderBrush="#7C3AED" BorderThickness="0,0,0,3" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                <TextBlock Text="Hệ thống tự động tính bảo hiểm 10.5% và thuế 10% dựa trên tổng thu nhập (Lương CB + Thưởng) thông qua TinhLuongService." 
                                           Foreground="#6D28D9" FontSize="11" TextWrapping="Wrap" LineHeight="16"/>
                            </Border>
                            <TextBlock Text="* Lưu ý: Khi nhấn Xác nhận, dữ liệu cũ của nhân viên trong tháng này sẽ bị ghi đè." 
                                       Foreground="#94A3B8" FontSize="10" TextWrapping="Wrap" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>