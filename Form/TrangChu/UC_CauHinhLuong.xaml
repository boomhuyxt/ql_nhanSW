<UserControl x:Class="ql_nhanSW.Form.TrangChu.UC_CauHinhLuong"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0A0010"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24">
            <TextBlock Text="Tính toán Lương nhân sự"
                       Foreground="#E9D5FF" FontSize="20" FontWeight="Bold" Margin="0,0,0,6"/>
            <TextBlock Text="Quản lý, điều chỉnh và phê duyệt chi trả lương cho nhân sự toàn hệ thống. Mọi thay đổi sẽ được ghi nhật ký hệ thống."
                       Foreground="#6B21A8" FontSize="12" Margin="0,0,0,20" TextWrapping="Wrap"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Background="#0D0020" BorderBrush="#3B0764" BorderThickness="1"
                            CornerRadius="12" Padding="16" Margin="0,0,0,14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <TextBlock Text="👤" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Chọn Nhân viên cần tính lương"
                                           Foreground="#E9D5FF" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1"
                                    CornerRadius="8" Margin="0,0,0,14">
                                <ComboBox x:Name="cmbNhanVien"
                                          Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                          Padding="8" FontSize="13" Foreground="#E9D5FF"
                                          SelectionChanged="cmbNhanVien_SelectionChanged">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding HoTen}" FontWeight="Bold" Width="120"/>
                                                <TextBlock Text=" | " Foreground="#6B21A8"/>
                                                <TextBlock Text="{Binding GioiTinh}" Width="50"/>
                                                <TextBlock Text=" | " Foreground="#6B21A8"/>
                                                <TextBlock Text="{Binding NgaySinh, StringFormat={}{0:dd/MM/yyyy}}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Border>

                            <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1" CornerRadius="10" Padding="12">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="42" Height="42" CornerRadius="21"
                                            Background="#2D0060" BorderBrush="#7C3AED" BorderThickness="1.5">
                                        <TextBlock Text="HR" Foreground="White" FontSize="13" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="txtHoTen" Text="Chưa chọn nhân viên" Foreground="#E9D5FF" FontSize="13" FontWeight="Bold"/>
                                        <TextBlock x:Name="txtMaNV" Text="MNV: -- | Giới tính: --"
                                                   Foreground="#6B21A8" FontSize="10" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Background="#0D0020" BorderBrush="#3B0764" BorderThickness="1"
                            CornerRadius="12" Padding="16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="⚡" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Nhập thông tin tính lương"
                                           Foreground="#E9D5FF" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Tháng" Grid.Row="0" Grid.Column="0" Foreground="#6B21A8" FontSize="12" VerticalAlignment="Center"/>
                                <Border Grid.Row="0" Grid.Column="1" Background="#150028" BorderBrush="#4C1D95" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10">
                                    <TextBox x:Name="txtThang" Background="Transparent" Foreground="#E9D5FF" BorderThickness="0" Padding="8,8"/>
                                </Border>

                                <TextBlock Text="Năm" Grid.Row="0" Grid.Column="3" Foreground="#6B21A8" FontSize="12" VerticalAlignment="Center"/>
                                <Border Grid.Row="0" Grid.Column="4" Background="#150028" BorderBrush="#4C1D95" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10">
                                    <TextBox x:Name="txtNam" Background="Transparent" Foreground="#E9D5FF" BorderThickness="0" Padding="8,8"/>
                                </Border>

                                <TextBlock Text="Lương cơ bản" Grid.Row="1" Grid.Column="0" Foreground="#6B21A8" FontSize="12" VerticalAlignment="Center"/>
                                <Border Grid.Row="1" Grid.Column="1" Background="#150028" BorderBrush="#4C1D95" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10">
                                    <TextBox x:Name="txtLuongCoBan" Text="0" Background="Transparent" Foreground="#E9D5FF" BorderThickness="0" Padding="8,8"/>
                                </Border>

                                <TextBlock Text="Thưởng/KPI" Grid.Row="1" Grid.Column="3" Foreground="#6B21A8" FontSize="12" VerticalAlignment="Center"/>
                                <Border Grid.Row="1" Grid.Column="4" Background="#150028" BorderBrush="#4C1D95" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10">
                                    <TextBox x:Name="txtThuong" Text="0" Background="Transparent" Foreground="#E9D5FF" BorderThickness="0" Padding="8,8"/>
                                </Border>

                                <TextBlock Text="Số ngày công" Grid.Row="2" Grid.Column="0" Foreground="#6B21A8" FontSize="12" VerticalAlignment="Center"/>
                                <Border Grid.Row="2" Grid.Column="1" Background="#150028" BorderBrush="#4C1D95" BorderThickness="1" CornerRadius="6">
                                    <TextBox x:Name="txtSoNgayCong" Text="26" Background="Transparent" Foreground="#E9D5FF" BorderThickness="0" Padding="8,8"/>
                                </Border>

                                <TextBlock Text="Khấu trừ (TĐ)" Grid.Row="2" Grid.Column="3" Foreground="#6B21A8" FontSize="11" VerticalAlignment="Center" ToolTip="Khấu trừ bảo hiểm và thuế tự động tính"/>
                                <Border Grid.Row="2" Grid.Column="4" Background="#1A0020" BorderBrush="#3B0764" BorderThickness="1" CornerRadius="6">
                                    <TextBox x:Name="txtKhauTru" Text="0" IsReadOnly="True" Background="Transparent" Foreground="#F87171" BorderThickness="0" Padding="8,8"/>
                                </Border>
                            </Grid>

                            <Button x:Name="btnTinhLuong" Content="🔢 Tính Lương (Áp dụng Thuế &amp; BH)"
                                    Background="#7C3AED" Foreground="White" FontWeight="SemiBold"
                                    Padding="20,10" Click="btnTinhLuong_Click" Height="43"/>

                            <StackPanel Orientation="Horizontal" Margin="0,20,0,16">
                                <TextBlock Text="📊" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Kết quả tính toán thực nhận" Foreground="#E9D5FF" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="LƯƠNG CƠ BẢN" Foreground="#6B21A8" FontSize="9" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Border Background="#150028" BorderBrush="#4C1D95" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                        <TextBlock x:Name="tbLuongCoBan" Text="0" Foreground="#E9D5FF" FontSize="14" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="THƯỞNG/KPI" Foreground="#6B21A8" FontSize="9" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Border Background="#0A2000" BorderBrush="#14532D" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                        <TextBlock x:Name="tbThuong" Text="0" Foreground="#4ADE80" FontSize="14" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="KHẤU TRỪ (TỔNG)" Foreground="#6B21A8" FontSize="9" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Border Background="#1F0000" BorderBrush="#7F1D1D" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                        <TextBlock x:Name="tbKhauTru" Text="0" Foreground="#F87171" FontSize="14" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Rectangle Height="1" Fill="#2D0060" Margin="0,0,0,16"/>

                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Tổng lương thực nhận"
                                               Foreground="#E9D5FF" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="Đã khấu trừ 10.5% BH và 10% Thuế TNCN."
                                               Foreground="#6B21A8" FontSize="11"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock x:Name="tbTongLuong" Text="0" Foreground="#A855F7" FontSize="24" FontWeight="Bold"/>
                                    <TextBlock Text=" VND" Foreground="#7C3AED" FontSize="14" FontWeight="Bold" VerticalAlignment="Bottom" Margin="5,0,0,5"/>
                                </StackPanel>
                            </Grid>

                            <Button Background="#7C3AED" BorderThickness="0" Cursor="Hand" 
                                    HorizontalAlignment="Stretch" Padding="0" Margin="0,20,0,8" 
                                    Click="btnXacNhanXuatLuong_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="15,10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙ " Foreground="White" FontSize="13"/>
                                    <TextBlock Text="Xác nhận &amp; Lưu vào hệ thống" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Background="#4C1D95" BorderBrush="#7C3AED" BorderThickness="1"
                            CornerRadius="12" Padding="16" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="THỐNG KÊ CHI TRẢ"
                                       Foreground="#E9D5FF" FontSize="10" FontWeight="Bold" Margin="0,0,0,14"/>
                            <TextBlock Text="Quỹ lương tháng hiện tại:" Foreground="#C4B5FD" FontSize="12" Margin="0,0,0,4"/>
                            <TextBlock Text="Đang cập nhật..." Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                            <Border Height="6" CornerRadius="3" Background="#3B0764">
                                <Border HorizontalAlignment="Left" Width="60" CornerRadius="3" Height="6" Background="#4ADE80"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Background="#0D0020" BorderBrush="#3B0764" BorderThickness="1"
                            CornerRadius="12" Padding="16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="📝" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Ghi chú nhanh" Foreground="#E9D5FF" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Background="#1A0035" BorderBrush="#7C3AED" BorderThickness="0,0,0,3" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                <TextBlock Text="Hệ thống tự động tính bảo hiểm 10.5% và thuế 10% theo TinhLuongService."
                                           Foreground="#D8B4FE" FontSize="11" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>