 <UserControl x:Class="ql_nhanSW.Form.TrangChu.UC_DashBoard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ql_nhanSW.Form"
        mc:Ignorable="d"
        
        Background="#0A0010" FontFamily="Segoe UI">
    <DockPanel LastChildFill="False">
        <Border DockPanel.Dock="Top"
                Background="#0D0020"
                Padding="24,16"
                BorderBrush="#2D0060"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center" Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="BẢNG ĐIỀU KHIỂN"
                                Foreground="#E9D5FF"
                                FontSize="18" FontWeight="Bold"
                                FontFamily="Segoe UI"/>
                    </StackPanel>

                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Border Background="#150028"
                        BorderBrush="#4C1D95" BorderThickness="1"
                        CornerRadius="8" Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE721;" 
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="12" 
                                    Foreground="#4C1D95"
                                    Margin="0,0,6,0" 
                                    VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center" Text="Tìm kiếm nhân sự..."
                                    Foreground="#4C1D95" FontSize="12"
                                    FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Border>                    
                    <Border Width="32" Height="32" CornerRadius="8"
                        Background="#150028" BorderBrush="#4C1D95" BorderThickness="1"
                        Margin="8,0,0,0" Cursor="Hand">
                        <TextBlock Foreground="#9D78CC" Text="🔔" FontSize="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                    </Border>
                    <Border Width="32" Height="32" CornerRadius="8"
                        Background="#150028" BorderBrush="#4C1D95" BorderThickness="1"
                        Margin="6,0,0,0" Cursor="Hand">
                        <Border Width="20" Height="20" CornerRadius="10"
                            Background="Transparent"
                            BorderBrush="#6B21A8" BorderThickness="1">
                            <TextBlock Text="?" 
                                    FontSize="13" 
                                    FontWeight="Bold"
                                    Foreground="#9D78CC"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Border>
                    <Button Click="BtnOpenChat_Click"
                            Background="Transparent" BorderThickness="1" BorderBrush="#4C1D95"
                            Cursor="Hand" Width="36" Height="36" Margin="6,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1E0040"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Viewbox Width="18" Height="18">
                            <Canvas Width="24" Height="24">
                               
                                <Rectangle Canvas.Left="4" Canvas.Top="3" Width="16" Height="11"
                                           RadiusX="3" RadiusY="3"
                                           Fill="Transparent" Stroke="#6B21A8" StrokeThickness="1.5"/>
                                
                                <Ellipse Canvas.Left="7.5" Canvas.Top="6.5" Width="2.5" Height="2.5"
                                         Fill="#9D78CC"/>
                               
                                <Ellipse Canvas.Left="14" Canvas.Top="6.5" Width="2.5" Height="2.5"
                                         Fill="#9D78CC"/>
                                
                                <Rectangle Canvas.Left="8.5" Canvas.Top="10.5" Width="7" Height="1.5"
                                           RadiusX="1" RadiusY="1" Fill="#9D78CC"/>
                                
                                <Rectangle Canvas.Left="5" Canvas.Top="15" Width="14" Height="7"
                                           RadiusX="2" RadiusY="2"
                                           Fill="Transparent" Stroke="#6B21A8" StrokeThickness="1.5"/>

                                <Line X1="12" Y1="3" X2="12" Y2="1" Stroke="Transparent" StrokeThickness="1.5"/>
                                
                                <Ellipse Canvas.Left="10" Canvas.Top="0" Width="4" Height="4"
                                         Fill="Transparent" Stroke="#6B21A8" StrokeThickness="1.5"/>
                               
                                <Rectangle Canvas.Left="2" Canvas.Top="16" Width="3" Height="5"
                                           RadiusX="1" RadiusY="1"
                                           Fill="Transparent" Stroke="#6B21A8" StrokeThickness="1.5"/>
                                
                                <Rectangle Canvas.Left="19" Canvas.Top="16" Width="3" Height="5"
                                           RadiusX="1" RadiusY="1"
                                           Fill="Transparent" Stroke="#6B21A8" StrokeThickness="1.5"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--KPI CARDS-->
        <StackPanel DockPanel.Dock="Top" Margin="24, 20, 24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!--TỔNG NHÂN SỰ-->
                <Border Grid.Column="0"
                        Background="#0D0020"
                        BorderBrush="#3B0764" BorderThickness="1"
                        CornerRadius="12" 
                        Padding="16" Margin="0,0,10,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="#1E0040" BorderBrush="#4C1D95" BorderThickness="1"
                                    HorizontalAlignment="Left">
                                <TextBlock Foreground="#6B21A8" Text="👥" FontSize="16"
                                            HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Background="#052E16" BorderBrush="#14532D" BorderThickness="1"
                                    CornerRadius="4" Padding="6,2">
                                <TextBlock Text="+12%" Foreground="#4ADE80" FontSize="11" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="Tổng nhân sự" Foreground="#6B21A8" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock Text="1,284" Foreground="#E9D5FF" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!--YÊU CẦU PHÊ DUYỆT-->
                <Border Grid.Column="1"
                        Background="#0D0020"
                        BorderBrush="#3B0764" BorderThickness="1"
                        CornerRadius="12" 
                        Padding="16" Margin="0,0,10,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="#1A1200" BorderBrush="#713F12" BorderThickness="1"
                                    HorizontalAlignment="Left">
                                <TextBlock Foreground="#FACC15" Text="📋" FontSize="16"
                                            HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Background="#1A1200" BorderBrush="#713F12" BorderThickness="1"
                                    CornerRadius="4" Padding="6,2">
                                <TextBlock Text="0%" Foreground="#FACC15" FontSize="11" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="Yêu cầu phê duyệt" Foreground="#6B21A8" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock Text="28" Foreground="#E9D5FF" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!--CHI PHÍ NHÂN SỰ-->
                <Border Grid.Column="2"
                        Background="#0D0020"
                        BorderBrush="#3B0764" BorderThickness="1"
                        CornerRadius="12" 
                        Padding="16" Margin="0,0,10,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="#0A2000" BorderBrush="#14532D" BorderThickness="1"
                                    HorizontalAlignment="Left">
                                <TextBlock Foreground="#4ADE80" Text="💰" FontSize="16"
                                            HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Background="#052E16" BorderBrush="#14532D" BorderThickness="1"
                                    CornerRadius="4" Padding="6,2">
                                <TextBlock Text="+4.5%" Foreground="#4ADE80" FontSize="11" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="Chi phí nhân sự" Foreground="#6B21A8" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock Text="đ2.4B" Foreground="#E9D5FF" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!--TỶ LỆ CHUYÊN CẦN-->
                <Border Grid.Column="3"
                        Background="#0D0020"
                        BorderBrush="#3B0764" BorderThickness="1"
                        CornerRadius="12" 
                        Padding="16" Margin="0,0,10,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="#1F0000" BorderBrush="#7F1D1D" BorderThickness="1"
                                    HorizontalAlignment="Left">
                                <TextBlock Foreground="#F87171" Text="📅" FontSize="16"
                                            HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Background="#1F0000" BorderBrush="#7F1D1D" BorderThickness="1"
                                    CornerRadius="4" Padding="6,2">
                                <TextBlock Text="-2%" Foreground="#F87171" FontSize="11" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="Tỷ lệ chuyên cần" Foreground="#6B21A8" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock Text="94.2%" Foreground="#E9D5FF" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>

        <!-- BOTTOM ROW -->
        <Grid DockPanel.Dock="Top" Margin="24,16,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- CỘT TRÁI: Bảng phê duyệt -->
            <Border Grid.Column="0" Background="#0D0020" BorderBrush="#3B0764" BorderThickness="1"
                    CornerRadius="12" Padding="15" Margin="0,0,13,175">
                <StackPanel>

                    <!-- Header -->
                    <Grid Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Foreground="#7C3AED" Text="👤" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Yêu cầu phê duyệt tài khoản"
                                       Foreground="#E9D5FF" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Xem tất cả →" Foreground="#7C3AED" FontSize="12"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand"/>
                    </Grid>

                    <!-- Col headers -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ỨNG VIÊN"     Foreground="#6B21A8" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="PHÒNG BAN"    Foreground="#6B21A8" FontSize="10" FontWeight="Bold" Margin="0,0,30,0"/>
                        <TextBlock Grid.Column="2" Text="NGÀY YÊU CẦU" Foreground="#6B21A8" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Grid.Column="3" Text="HÀNH ĐỘNG"    Foreground="#6B21A8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Grid>
                    <Rectangle Height="1" Fill="#2D0060" Margin="0,0,0,12"/>

                    <!-- Row 1 -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Border Width="32" Height="32" CornerRadius="16"
                                    Background="#1E0040" BorderBrush="#7C3AED" BorderThickness="1"
                                    VerticalAlignment="Center">
                                <TextBlock Text="NL" Foreground="White" FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Nguyễn Lam"         Foreground="#D8B4FE" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="lam.ngo@company.com" Foreground="#6B21A8" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#1E0040" BorderBrush="#6D28D9" BorderThickness="1"
                                CornerRadius="4" Padding="6,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="MARKET" Foreground="#C084FC" FontSize="11"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Hôm nay" Foreground="#9D78CC" FontSize="11"/>
                            <TextBlock Text="08:45"   Foreground="#4C1D95" FontSize="10"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button Background="#14532D" BorderThickness="1" BorderBrush="#14532D"
                                    Padding="8,3" FontSize="11" Cursor="Hand" Margin="0,0,4,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="Duyệt" Foreground="#22C55E" FontSize="11"/>
                            </Button>
                            <Button Background="#4C0519" BorderThickness="0"
                                    Padding="8,3" FontSize="11" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="Từ chối" Foreground="#F87171" FontSize="11"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Row 2 -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Border Width="32" Height="32" CornerRadius="16"
                                    Background="#0A2000" BorderBrush="#7C3AED" BorderThickness="1"
                                    VerticalAlignment="Center">
                                <TextBlock Text="TH" Foreground="White" FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Trần Hoàng"             Foreground="#D8B4FE" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="hoang.tran@company.com" Foreground="#6B21A8" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#1E0040" BorderBrush="#6D28D9" BorderThickness="1"
                                CornerRadius="4" Padding="6,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="ENGINE" Foreground="#C084FC" FontSize="11"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Hôm qua," Foreground="#9D78CC" FontSize="11"/>
                            <TextBlock Text="16:20"    Foreground="#4C1D95" FontSize="10"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button Background="#14532D" BorderThickness="0"
                                    Padding="8,3" Cursor="Hand" Margin="0,0,4,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="Duyệt" Foreground="#22C55E" FontSize="11"/>
                            </Button>
                            <Button Background="#4C0519" BorderThickness="0" Padding="8,3" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="Từ chối" Foreground="#F87171" FontSize="11"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Row 3 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Border Width="32" Height="32" CornerRadius="16"
                                    Background="#2D0060" BorderBrush="#7C3AED" BorderThickness="1"
                                    VerticalAlignment="Center">
                                <TextBlock Text="VT" Foreground="White" FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Vũ Thảo"            Foreground="#D8B4FE" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="thao.vu@company.com" Foreground="#6B21A8" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#1E0040" BorderBrush="#6D28D9" BorderThickness="1"
                                CornerRadius="4" Padding="6,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="HUMAN" Foreground="#C084FC" FontSize="11"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="22 Th10," Foreground="#9D78CC" FontSize="11"/>
                            <TextBlock Text="2023"     Foreground="#4C1D95" FontSize="10"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button Background="#14532D" BorderThickness="0"
                                    Padding="8,3" Cursor="Hand" Margin="0,0,4,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="Duyệt" Foreground="#22C55E" FontSize="11"/>
                            </Button>
                            <Button Background="#4C0519" BorderThickness="0" Padding="8,3" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="Từ chối" Foreground="#F87171" FontSize="11"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- CỘT PHẢI: Panel lương -->
            <Border Grid.Column="1" Background="#0D0020" BorderBrush="#3B0764" BorderThickness="1"
                    CornerRadius="12" Padding="15">
                <StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="💰" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Trạng thái lương tháng 10"
                                   Foreground="#E9D5FF" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Đã thanh toán -->
                    <Border Background="#0A0018" BorderBrush="#3B0764" BorderThickness="1"
                            CornerRadius="8" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#4ADE80"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Đã thanh toán" Foreground="#4ADE80" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="đ1,850B" Foreground="#4ADE80" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                            <TextBlock Text="842 nhân viên" Foreground="#6B21A8" FontSize="10" Margin="14,0,0,6"/>
                            <Border Height="5" CornerRadius="2" Background="#1A0035">
                                <Border HorizontalAlignment="Left" Width="160" CornerRadius="2" Height="5" Background="#4ADE80"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Đang chờ -->
                    <Border Background="#0A0018" BorderBrush="#3B0764" BorderThickness="1"
                            CornerRadius="8" Padding="12" Margin="0,0,0,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#FACC15"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Đang chờ xử lý" Foreground="#FACC15" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="đ550M" Foreground="#FACC15" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                            <TextBlock Text="442 nhân viên" Foreground="#6B21A8" FontSize="10" Margin="14,0,0,6"/>
                            <Border Height="5" CornerRadius="2" Background="#1A0035">
                                <Border HorizontalAlignment="Left" Width="55" CornerRadius="2" Height="5" Background="#FACC15"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="NHÂN VIÊN GẦN ĐÂY" Foreground="#4C1D95" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="28" Height="28" CornerRadius="14"
                                    Background="#2D0060" BorderBrush="#7C3AED" BorderThickness="1">
                                <TextBlock Text="LQ" Foreground="White" FontSize="9" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Lê Minh Quân" Foreground="#D8B4FE" FontSize="12"
                                       Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="#052E16" BorderBrush="#14532D" BorderThickness="1"
                                CornerRadius="4" Padding="6,2">
                            <TextBlock Text="PAID" Foreground="#4ADE80" FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="28" Height="28" CornerRadius="14"
                                    Background="#1E0040" BorderBrush="#7C3AED" BorderThickness="1">
                                <TextBlock Text="PV" Foreground="White" FontSize="9" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Phạm Thúy Vy" Foreground="#D8B4FE" FontSize="12"
                                       Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="#1A1200" BorderBrush="#713F12" BorderThickness="1"
                                CornerRadius="4" Padding="6,2">
                            <TextBlock Text="PENDING" Foreground="#FACC15" FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="28" Height="28" CornerRadius="14"
                                    Background="#0A2000" BorderBrush="#7C3AED" BorderThickness="1">
                                <TextBlock Text="DN" Foreground="White" FontSize="9" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Đỗ Thành Nam" Foreground="#D8B4FE" FontSize="12"
                                       Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="#052E16" BorderBrush="#14532D" BorderThickness="1"
                                CornerRadius="4" Padding="6,2">
                            <TextBlock Text="PAID" Foreground="#4ADE80" FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </Grid>

                    <Button Background="#7C3AED" BorderThickness="0" Cursor="Hand"
                            HorizontalAlignment="Stretch" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="5">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#6D28D9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="Xuất báo cáo lương" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
