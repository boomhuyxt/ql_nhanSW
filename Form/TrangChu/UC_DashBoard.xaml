<UserControl x:Class="ql_nhanSW.Form.TrangChu.UC_DashBoard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC" FontFamily="Segoe UI">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="#FFFFFF" Padding="24,16" BorderBrush="#E9D5FF" BorderThickness="0,0,0,2">
            <TextBlock Text="QUẢN TRỊ HỆ THỐNG &amp; PHÊ DUYỆT" Foreground="#4C1D95" FontSize="18" FontWeight="Bold"/>
        </Border>

        <TabControl Background="Transparent" BorderThickness="0" Margin="10">
            <TabItem Header="Phê duyệt mới">
                <StackPanel>
                    <StackPanel Margin="14, 10, 14,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#A855F7" BorderThickness="1.5" CornerRadius="12" Padding="16" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="👥 Tổng nhân sự (Hệ thống)" Foreground="#6B21A8" FontSize="11" Margin="0,0,0,4" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="txtTongNhanSu" Text="0" Foreground="#7C3AED" FontSize="26" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#7C3AED" BorderThickness="1.5" CornerRadius="12" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="⏳ Chờ cấp quyền hoạt động" Foreground="#6B21A8" FontSize="11" Margin="0,0,0,4" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="txtChoDuyetCount" Text="0" Foreground="#6D28D9" FontSize="26" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <Border Background="#FFFFFF" BorderBrush="#E9D5FF" BorderThickness="1" CornerRadius="12" Padding="20" Margin="14,16,14,14">
                        <DockPanel Height="350">
                            <TextBlock DockPanel.Dock="Top" Text="🔔 DANH SÁCH CHỜ PHÊ DUYỆT" Foreground="#6D28D9" FontWeight="Bold" FontSize="13" Margin="0,0,0,15"/>
                            <Grid DockPanel.Dock="Top" Margin="0,0,18,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="180"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="TÀI KHOẢN" Foreground="#9D78CC" FontSize="10" FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Text="PHÒNG BAN" Foreground="#9D78CC" FontSize="10" FontWeight="Bold"/>
                                <TextBlock Grid.Column="2" Text="VAI TRÒ" Foreground="#9D78CC" FontSize="10" FontWeight="Bold"/>
                            </Grid>
                            <Rectangle DockPanel.Dock="Top" Height="1.5" Fill="#F5F3FF" Margin="0,0,0,12"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="ItemsPheDuyet">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#F5F3FF" BorderThickness="0,0,0,1" Padding="0,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="1.5*"/>
                                                        <ColumnDefinition Width="1.5*"/>
                                                        <ColumnDefinition Width="180"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding TenDangNhap}" Foreground="#1E1B4B" FontSize="13" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding Email}" Foreground="#6B21A8" FontSize="11" Opacity="0.8"/>
                                                    </StackPanel>
                                                    <ComboBox Grid.Column="1" x:Name="CmbPhongBan" Margin="5,0" Height="32" DisplayMemberPath="TenPhongBan" SelectedValuePath="MaPhongBan" Loaded="CmbPhongBan_Loaded" Background="#FDFBFF"/>
                                                    <ComboBox Grid.Column="2" x:Name="CmbVaiTro" Margin="5,0" Height="32" DisplayMemberPath="TenVaiTro" SelectedValuePath="MaVaiTro" Loaded="CmbVaiTro_Loaded" Background="#FDFBFF"/>
                                                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Button Content="Duyệt" Background="#7C3AED" Foreground="White" Width="75" Height="30" Click="BtnDuyet_Click" Tag="{Binding}" Margin="0,0,5,0"/>
                                                        <Button Content="Hủy" Background="Transparent" Foreground="#EF4444" BorderBrush="#FEE2E2" BorderThickness="1" Width="75" Height="30" Click="BtnTuChoi_Click" Tag="{Binding}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </StackPanel>
            </TabItem>

            <TabItem Header="Quản lý Phòng ban &amp; Vai trò">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" CornerRadius="12" BorderBrush="#E9D5FF" BorderThickness="1" Padding="15" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="DANH MỤC PHÒNG BAN" Foreground="#6D28D9" FontWeight="Bold" Margin="0,0,0,15"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBox x:Name="txtTenPB" Width="170" Height="32" VerticalContentAlignment="Center" BorderBrush="#DDD6FE" Margin="0,0,5,0"/>
                                <Button Content="Thêm" Background="#7C3AED" Foreground="White" Width="67" Click="BtnThemPB_Click"/>
                            </StackPanel>
                            <ListBox x:Name="lstPhongBan" Height="350" BorderThickness="0" DisplayMemberPath="TenPhongBan" Background="Transparent"/>
                            <Button Content="Xóa phòng ban" Background="#EF4444" Foreground="White" Height="32" Margin="0,10,0,0" Click="BtnXoaPB_Click"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="12" BorderBrush="#E9D5FF" BorderThickness="1" Padding="15">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="ĐIỀU CHỈNH TÀI KHOẢN HỆ THỐNG" Foreground="#6D28D9" FontWeight="Bold" Margin="0,0,0,15"/>
                            <ScrollViewer>
                                <ItemsControl x:Name="ItemsTaiKhoanHienTai">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#F5F3FF" BorderThickness="0,0,0,1" Padding="5,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="180"/>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="90"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding TenDangNhap}" FontWeight="Bold" Foreground="#1E1B4B"/>
                                                        <TextBlock Text="{Binding Email}" FontSize="10" Foreground="#6B21A8" Opacity="0.7"/>
                                                    </StackPanel>
                                                    <ComboBox Grid.Column="1" x:Name="CmbUpdatePB" Margin="5,0" Height="28" DisplayMemberPath="TenPhongBan" SelectedValuePath="MaPhongBan" Loaded="CmbPB_Update_Loaded"/>
                                                    <ComboBox Grid.Column="2" x:Name="CmbUpdateVT" Margin="5,0" Height="28" DisplayMemberPath="TenVaiTro" SelectedValuePath="MaVaiTro" Loaded="CmbVT_Update_Loaded"/>
                                                    <Button Grid.Column="3" Content="Lưu" Background="#7C3AED" Foreground="White" Width="60" Height="28" Click="BtnSaveAccountUpdate_Click" Tag="{Binding}"/>
                                                    <Button Grid.Column="4" Click="BtnToggleStatus_Click" Tag="{Binding}" Width="80" Height="28" Margin="5,0,0,0">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Content" Value="Chặn (1)"/>
                                                                <Setter Property="Background" Value="#FEE2E2"/>
                                                                <Setter Property="Foreground" Value="#EF4444"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding TrangThai}" Value="0">
                                                                        <Setter Property="Content" Value="Mở lại (0)"/>
                                                                        <Setter Property="Background" Value="#DCFCE7"/>
                                                                        <Setter Property="Foreground" Value="#16A34A"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Phê duyệt Nghỉ phép">
                <Border Background="White" CornerRadius="12" BorderBrush="#E9D5FF" BorderThickness="1" Padding="15" Margin="10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="DANH SÁCH ĐƠN NGHỈ PHÉP CHỜ DUYỆT" Foreground="#6D28D9" FontWeight="Bold" Margin="0,0,0,15"/>
                        <ScrollViewer>
                            <ItemsControl x:Name="ItemsNghiPhep">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#F5F3FF" BorderThickness="0,0,0,1" Padding="10,15">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="220"/>
                                                    <ColumnDefinition Width="180"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding NhanVien.HoTen}" FontWeight="Bold" Foreground="#1E1B4B" FontSize="13"/>
                                                    <TextBlock Text="Email: Nhân viên hệ thống" FontSize="10" Foreground="#6B21A8" Opacity="0.7"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding NgayBatDau, StringFormat='Từ: dd/MM/yyyy'}" FontSize="12" Foreground="#4C1D95"/>
                                                    <TextBlock Text="{Binding NgayKetThuc, StringFormat='Đến: dd/MM/yyyy'}" FontSize="12" Foreground="#4C1D95"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="2" Text="{Binding LoaiNghi}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#6B21A8"/>

                                                <Button Grid.Column="6" Content="👁 Xem minh chứng" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" 
                                                        Foreground="#7C3AED" FontWeight="Bold" Click="BtnXemMinhChung_Click" Tag="{Binding LyDo}"/>

                                                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button Content="Chấp nhận" Background="#16A34A" Foreground="White" Width="100" Height="32" 
                                                            Margin="0,0,10,0" Click="BtnDuyetNghiPhep_Click" Tag="{Binding}">
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="6"/>
                                                            </Style>
                                                        </Button.Resources>
                                                    </Button>
                                                    <Button Content="Từ chối" Background="#EF4444" Foreground="White" Width="100" Height="32" 
                                                            Click="BtnTuChoiNghiPhep_Click" Tag="{Binding}">
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="6"/>
                                                            </Style>
                                                        </Button.Resources>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>