<UserControl x:Class="ql_nhanSW.Form.TrangChu.UC_NhanSu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             
             Background="#0A0010"
             FontFamily="Segoe UI">

    <DockPanel LastChildFill="False">

        <!-- TOPBAR -->
        <Border DockPanel.Dock="Top"
                Background="#0D0020"
                Padding="24,16"
                BorderBrush="#2D0060"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="QUẢN LÝ NHÂN SỰ"
                       Foreground="#E9D5FF"
                       FontSize="18" FontWeight="Bold"
                       FontFamily="Segoe UI"/>
                    </StackPanel>

                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Border Background="#150028"
                BorderBrush="#4C1D95" BorderThickness="1"
                CornerRadius="8" Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE721;" 
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="12" 
                           Foreground="#4C1D95"
                           Margin="0,0,6,0" 
                           VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center" Text="Tìm kiếm nhân sự..."
                           Foreground="#4C1D95" FontSize="12"
                           FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Border>
                    <Border Width="32" Height="32" CornerRadius="8"
                Background="#150028" BorderBrush="#4C1D95" BorderThickness="1"
                Margin="8,0,0,0" Cursor="Hand">
                        <TextBlock Foreground="#4C1D95" Text="🔔" FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                    </Border>
                    <Border Width="32" Height="32" CornerRadius="8"
                Background="#150028" BorderBrush="#4C1D95" BorderThickness="1"
                Margin="6,0,0,0" Cursor="Hand">
                        <Border Width="20" Height="20" CornerRadius="10"
                    Background="Transparent"
                    BorderBrush="#6B21A8" BorderThickness="1">
                            <TextBlock Text="?" 
                           FontSize="13" 
                           FontWeight="Bold"
                           Foreground="#9D78CC"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel DockPanel.Dock="Top" Margin="24,20,24,0">
            <TextBlock Text="Hệ Thống Chấm Công FaceID"
                       Foreground="#E9D5FF" FontSize="22"
                       FontWeight="Bold" Margin="0,0,0,6"/>
            <TextBlock Text="Vui lòng di chuyển đến trước camera để thực hiện chấm công"
                       Foreground="#6B21A8" FontSize="12"
                       Margin="0,0,0,20"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- CAMERA BOX -->
                <Border Grid.Column="0"
                        Background="#080015"
                        BorderBrush="#3B0764" BorderThickness="1"
                        CornerRadius="12" Margin="0,0,16,0"
                        Height="340" VerticalAlignment="Top">
                    <Grid>
                        <!-- Scanning text -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Margin="16,16,0,0">
                            <Ellipse Width="8" Height="8" Fill="#A855F7" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Đang nhận diện..." Foreground="#6B21A8" FontSize="12"/>
                        </StackPanel>

                        <!-- Camera placeholder -->
                        <Border Width="260" Height="200"
                                Background="Transparent"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <!-- 4 góc khung -->
                            <!-- Góc trên trái -->
                            <Canvas>
                                <Border Canvas.Left="0" Canvas.Top="0"
                                        Width="30" Height="3" Background="#4C1D95" CornerRadius="2"/>
                                <Border Canvas.Left="0" Canvas.Top="0"
                                        Width="3" Height="30" Background="#4C1D95" CornerRadius="2"/>
                                <!-- Góc trên phải -->
                                <Border Canvas.Right="0" Canvas.Top="0"
                                        Width="30" Height="3" Background="#4C1D95" CornerRadius="2"
                                        HorizontalAlignment="Right"/>
                                <Border Canvas.Right="0" Canvas.Top="0"
                                        Width="3" Height="30" Background="#4C1D95" CornerRadius="2"
                                        HorizontalAlignment="Right"/>
                                <!-- Góc dưới trái -->
                                <Border Canvas.Left="0" Canvas.Bottom="0"
                                        Width="30" Height="3" Background="#4C1D95" CornerRadius="2"
                                        VerticalAlignment="Bottom"/>
                                <Border Canvas.Left="0" Canvas.Bottom="0"
                                        Width="3" Height="30" Background="#4C1D95" CornerRadius="2"
                                        VerticalAlignment="Bottom"/>
                                <!-- Góc dưới phải -->
                                <Border Canvas.Right="0" Canvas.Bottom="0"
                                        Width="30" Height="3" Background="#4C1D95" CornerRadius="2"
                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                                <Border Canvas.Right="0" Canvas.Bottom="0"
                                        Width="3" Height="30" Background="#4C1D95" CornerRadius="2"
                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                            </Canvas>
                        </Border>
                    </Grid>
                </Border>

                <!-- RIGHT PANEL -->
                <StackPanel Grid.Column="1">

                    <!-- Trạng thái nhận diện -->
                    <Border Background="#0D0020" BorderBrush="#3B0764" BorderThickness="1"
                            CornerRadius="12" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Trạng thái nhận diện"
                                           Foreground="#9D78CC" FontSize="12"/>
                                <Border HorizontalAlignment="Right"
                                        Background="#052E16" BorderBrush="#14532D" BorderThickness="1"
                                        CornerRadius="4" Padding="8,3">
                                    <TextBlock Text="Thành công" Foreground="#4ADE80" FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </Grid>

                            <!-- Avatar + Tên -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="42" Height="42" CornerRadius="21"
                                        Background="#2D0060" BorderBrush="#7C3AED" BorderThickness="1.5">
                                    <TextBlock Text="SJ" Foreground="White" FontSize="13" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Đã nhận diện khuôn mặt -" Foreground="#6B21A8" FontSize="10"/>
                                    <TextBlock Text="Chào mừng, Sarah Jenkins" Foreground="#E9D5FF" FontSize="12" FontWeight="Bold"/>
                                    <TextBlock Text="Chuyên viên thiết kế" Foreground="#6B21A8" FontSize="10"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Nút Vào ca / Tan ca -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Background="#7C3AED" BorderThickness="0"
                                        Cursor="Hand" Margin="0,0,6,0" Padding="0,8">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#6D28D9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="→ " Foreground="White" FontSize="12"/>
                                        <TextBlock Text="Vào ca" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Background="Transparent"
                                        BorderBrush="#3B0764" BorderThickness="1"
                                        Cursor="Hand" Margin="6,0,0,0" Padding="0,8">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#1A0035"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="← " Foreground="#9D78CC" FontSize="12"/>
                                        <TextBlock Text="Tan ca" Foreground="#9D78CC" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Lịch sử vào/ra -->
                    <Border Background="#0D0020" BorderBrush="#3B0764" BorderThickness="1"
                            CornerRadius="12" Padding="14">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Lịch sử vào/ra"
                                           Foreground="#E9D5FF" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Xem tất cả →" Foreground="#7C3AED" FontSize="11"
                                           HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand"/>
                            </Grid>

                            <!-- Header -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="TRẠNG THÁI" Foreground="#6B21A8" FontSize="9" FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Text="THỜI GIAN"  Foreground="#6B21A8" FontSize="9" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                            <Rectangle Height="1" Fill="#2D0060" Margin="0,0,0,10"/>

                            <!-- Row 1 -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Border Width="28" Height="28" CornerRadius="14"
                                            Background="#1E0040" BorderBrush="#7C3AED" BorderThickness="1">
                                        <TextBlock Text="MC" Foreground="White" FontSize="8" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Michael Chang" Foreground="#D8B4FE" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Text="Đã vào ca" Foreground="#4ADE80" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="06:15 AM"
                                           Foreground="#6B21A8" FontSize="11"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Row 2 -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Border Width="28" Height="28" CornerRadius="14"
                                            Background="#0A2000" BorderBrush="#7C3AED" BorderThickness="1">
                                        <TextBlock Text="EW" Foreground="White" FontSize="8" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Emma Wilson" Foreground="#D8B4FE" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Text="Đã vào ca" Foreground="#4ADE80" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="09:02 AM"
                                           Foreground="#6B21A8" FontSize="11"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Row 3 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Border Width="28" Height="28" CornerRadius="14"
                                            Background="#2D0060" BorderBrush="#7C3AED" BorderThickness="1">
                                        <TextBlock Text="DM" Foreground="White" FontSize="8" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="David Miller" Foreground="#D8B4FE" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Text="Đã vào ca" Foreground="#4ADE80" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="09:15 AM"
                                           Foreground="#6B21A8" FontSize="11"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </StackPanel>
    </DockPanel>
</UserControl>