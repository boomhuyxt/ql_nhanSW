<UserControl x:Class="ql_nhanSW.Form.TrangChu.UC_NhanSu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC"
             FontFamily="Segoe UI"
             Unloaded="UserControl_Unloaded">

    <DockPanel LastChildFill="False">
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#FFFFFF" Padding="24,16"
                BorderBrush="#E9D5FF" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Grid.Column="0">
                    <TextBlock Text="QUẢN LÝ NHÂN SỰ" Foreground="#4C1D95"
                               FontSize="18" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Border Background="#F5F3FF" BorderBrush="#DDD6FE" BorderThickness="1"
                            CornerRadius="8" Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="12" Foreground="#7C3AED" Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Tìm kiếm nhân sự..." Foreground="#9D78CC" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel DockPanel.Dock="Top" Margin="24,20,24,0">
            <TextBlock Text="Hệ Thống Chấm Công FaceID" Foreground="#1E1B4B" FontSize="22"
                       FontWeight="Bold" Margin="0,0,0,6"/>
            <TextBlock Text="Vui lòng di chuyển đến trước camera để thực hiện chấm công"
                       Foreground="#64748B" FontSize="12" Margin="0,0,0,20"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- Camera -->
                <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E9D5FF" BorderThickness="1"
                        CornerRadius="12" Margin="0,0,16,0" Height="400" VerticalAlignment="Top">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Opacity="0.05" Color="#7C3AED"/>
                    </Border.Effect>
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                                    VerticalAlignment="Top" Margin="16,16,0,0">
                            <Ellipse Width="8" Height="8" Fill="#7C3AED" Margin="0,0,8,0"/>
                            <TextBlock Text="Hệ thống đang sẵn sàng..." Foreground="#6D28D9"
                                       FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                        <Border Width="320" Height="240" Background="#F1F5F9"
                                HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="8">
                            <Grid>
                                <Image x:Name="imgCamera" Stretch="UniformToFill"/>
                                <Canvas IsHitTestVisible="False">
                                    <Border Canvas.Left="0" Canvas.Top="0" Width="30" Height="3" Background="#7C3AED" CornerRadius="2"/>
                                    <Border Canvas.Left="0" Canvas.Top="0" Width="3" Height="30" Background="#7C3AED" CornerRadius="2"/>
                                    <Border Canvas.Right="0" Canvas.Top="0" Width="30" Height="3" Background="#7C3AED" CornerRadius="2"/>
                                    <Border Canvas.Right="0" Canvas.Top="0" Width="3" Height="30" Background="#7C3AED" CornerRadius="2"/>
                                    <Border Canvas.Left="0" Canvas.Bottom="0" Width="30" Height="3" Background="#7C3AED" CornerRadius="2"/>
                                    <Border Canvas.Left="0" Canvas.Bottom="0" Width="3" Height="30" Background="#7C3AED" CornerRadius="2"/>
                                    <Border Canvas.Right="0" Canvas.Bottom="0" Width="30" Height="3" Background="#7C3AED" CornerRadius="2"/>
                                    <Border Canvas.Right="0" Canvas.Bottom="0" Width="3" Height="30" Background="#7C3AED" CornerRadius="2"/>
                                </Canvas>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Phần bên phải -->
                <StackPanel Grid.Column="1">
                    <Border Background="#FFFFFF" BorderBrush="#E9D5FF" BorderThickness="1"
                            CornerRadius="12" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <TextBlock Text="Trạng thái" Foreground="#64748B" FontSize="12" FontWeight="SemiBold"/>
                                <Border HorizontalAlignment="Right" Background="#DCFCE7" Padding="8,3" CornerRadius="4">
                                    <TextBlock Text="Thành công" Foreground="#16A34A" FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </Grid>

                            <!-- Avatar + Thông tin người dùng (đã có x:Name) -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Width="45" Height="45" CornerRadius="22.5" Background="#F5F3FF"
                                        BorderBrush="#7C3AED" BorderThickness="1.5">
                                    <Image x:Name="imgUserAvatar" Stretch="UniformToFill">
                                        <Image.Clip>
                                            <EllipseGeometry RadiusX="22.5" RadiusY="22.5" Center="22.5,22.5"/>
                                        </Image.Clip>
                                    </Image>
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Chào mừng trở lại," Foreground="#64748B" FontSize="10"/>
                                    <TextBlock x:Name="txtHoTen" Text="Sarah Jenkins" 
                                               Foreground="#1E1B4B" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock x:Name="txtPhongBan" Text="Phòng Thiết kế" 
                                               Foreground="#7C3AED" FontSize="11" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Button chấm công -->
                            <Button x:Name="btnChamCong" Click="BtnChamCong_Click"
                                    Height="52" Cursor="Hand" FontSize="16" FontWeight="SemiBold">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="#7C3AED" CornerRadius="10">
                                            <TextBlock x:Name="txtButtonText" Text="Vào ca" 
                                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#6D28D9"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Lịch sử -->
                    <Border Background="#FFFFFF" BorderBrush="#E9D5FF" BorderThickness="1"
                            CornerRadius="12" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Lịch sử vào/ra hôm nay" Foreground="#1E1B4B" 
                                       FontSize="13" FontWeight="Bold" Margin="0,0,0,12"/>
                            <StackPanel x:Name="spLichSu"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </DockPanel>
</UserControl>